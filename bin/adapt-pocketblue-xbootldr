#!/usr/bin/env python3
"""Adapt one PocketBlue XBOOTLDR image for frankensargo's LVM contract."""

from __future__ import annotations

import argparse
import errno
import hashlib
import os
import re
import shutil
import stat
import subprocess
import sys
import tempfile
from pathlib import Path


TITLE = "PocketBlue sdm670 Phosh (frankensargo LVM)"
ENTRY_DIR = "/loader/entries"
ENTRY_NAME_RE = re.compile(r"[A-Za-z0-9][A-Za-z0-9._+-]*\.conf\Z")
ARTIFACT_PATH_RE = re.compile(r"/[A-Za-z0-9._+@/-]+\Z")
REQUIRED_FIELDS = ("title", "options", "linux", "initrd", "fdtdir")
PAYLOAD_KEYS = ("root=", "boot=", "ostree=")
REMOVE_KEYS = ("console=", "rd.lvm.lv=", "sysrq_always_enabled=")
APPEND_TOKENS = (
    "console=tty0",
    "console=ttyMSM0,115200n8",
    "rd.lvm.lv=franken/pocketblue-root",
    "rd.lvm.lv=franken/pocketblue-xbootldr",
    "rd.lvm.lv=franken/pocketblue-esp",
    "sysrq_always_enabled=1",
)
MAX_ENTRY_BYTES = 1024 * 1024


class AdaptError(RuntimeError):
    pass


def fail(message: str) -> "None":
    raise AdaptError(message)


def sha256_file(path: Path) -> str:
    digest = hashlib.sha256()
    with path.open("rb", buffering=0) as stream:
        while block := stream.read(1024 * 1024):
            digest.update(block)
    return digest.hexdigest()


def require_tool(name: str) -> str:
    path = shutil.which(name)
    if path is None:
        fail(f"required host tool is unavailable: {name}")
    return path


def run(command: list[str]) -> subprocess.CompletedProcess[bytes]:
    environment = os.environ.copy()
    environment["LC_ALL"] = "C"
    try:
        return subprocess.run(
            command,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            check=False,
            env=environment,
        )
    except OSError as error:
        fail(f"cannot execute {command[0]}: {error}")


def debugfs(debugfs_path: str, image: Path, request: str, *, write: bool = False) -> bytes:
    command = [debugfs_path]
    if write:
        command.append("-w")
    command.extend(["-R", request, str(image)])
    result = run(command)
    if result.returncode != 0:
        detail = result.stderr.decode("utf-8", "replace").strip()
        fail(f"debugfs request failed ({request!r}): {detail or 'no diagnostic'}")
    return result.stdout


def entry_names(debugfs_path: str, image: Path) -> list[str]:
    listing = debugfs(debugfs_path, image, f"ls -p {ENTRY_DIR}").decode(
        "utf-8", "strict"
    )
    names: list[str] = []
    for line in listing.splitlines():
        match = re.fullmatch(r"/\d+/([0-7]+)/\d+/\d+/(.*?)/\d*/", line)
        if match is None:
            continue
        mode = match.group(1)
        name = match.group(2)
        if name in (".", "..") or not name.endswith(".conf"):
            continue
        if not ENTRY_NAME_RE.fullmatch(name):
            fail(f"unsafe Type #1 entry name: {name!r}")
        if not mode.startswith("100"):
            fail(f"Type #1 entry is not a regular file: {name}")
        names.append(name)
    if len(names) != 1:
        fail(f"expected exactly one {ENTRY_DIR}/*.conf entry, found {len(names)}")
    return names


def read_entry(debugfs_path: str, image: Path, name: str) -> bytes:
    data = debugfs(debugfs_path, image, f"cat {ENTRY_DIR}/{name}")
    if not data or len(data) > MAX_ENTRY_BYTES:
        fail("Type #1 entry is empty or exceeds the size limit")
    return data


def parse_entry(data: bytes) -> tuple[list[tuple[str, str, str]], dict[str, str]]:
    if b"\0" in data or b"\r" in data:
        fail("Type #1 entry contains NUL or CR bytes")
    try:
        text = data.decode("utf-8")
    except UnicodeDecodeError as error:
        fail(f"Type #1 entry is not UTF-8: {error}")
    parsed: list[tuple[str, str, str]] = []
    fields: dict[str, str] = {}
    for raw in text.splitlines(keepends=True):
        ending = "\n" if raw.endswith("\n") else ""
        content = raw[:-1] if ending else raw
        stripped = content.strip()
        if not stripped or stripped.startswith("#"):
            parsed.append(("", content, ending))
            continue
        pieces = stripped.split(None, 1)
        key = pieces[0].lower()
        value = pieces[1].strip() if len(pieces) == 2 else ""
        if key in REQUIRED_FIELDS:
            if key in fields:
                fail(f"Type #1 entry repeats required field: {key}")
            if not value:
                fail(f"Type #1 entry has an empty required field: {key}")
            fields[key] = value
        parsed.append((key, content, ending))
    missing = [key for key in REQUIRED_FIELDS if key not in fields]
    if missing:
        fail(f"Type #1 entry lacks required field(s): {', '.join(missing)}")
    for key in ("linux", "initrd", "fdtdir"):
        value = fields[key]
        components = value.split("/")[1:]
        if (
            not ARTIFACT_PATH_RE.fullmatch(value)
            or not components
            or any(component in ("", ".", "..") for component in components)
        ):
            fail(f"Type #1 {key} is not one absolute artifact path")
    return parsed, fields


def validate_artifacts(debugfs_path: str, image: Path, fields: dict[str, str]) -> None:
    expected_types = {"linux": "regular", "initrd": "regular", "fdtdir": "directory"}
    for key, expected_type in expected_types.items():
        path = fields[key]
        output = debugfs(debugfs_path, image, f"stat {path}").decode("utf-8", "strict")
        match = re.search(r"^Inode:\s+\d+\s+Type:\s+(\S+)", output, re.MULTILINE)
        actual_type = match.group(1) if match else "missing"
        if actual_type != expected_type:
            fail(
                f"Type #1 {key} artifact {path} is {actual_type}, "
                f"expected {expected_type}"
            )


def adapt_entry(data: bytes) -> tuple[bytes, dict[str, str]]:
    lines, fields = parse_entry(data)
    options = fields["options"]
    if options != options.strip() or any(character.isspace() and character != " " for character in options):
        fail("Type #1 options use noncanonical whitespace")
    tokens = options.split(" ")
    if not tokens or any(not token for token in tokens):
        fail("Type #1 options use noncanonical whitespace")
    payload = {key: [token for token in tokens if token.startswith(key)] for key in PAYLOAD_KEYS}
    for key, matches in payload.items():
        if len(matches) != 1 or matches[0] == key:
            fail(f"Type #1 options require exactly one nonempty {key} payload token")
    retained = [token for token in tokens if not token.startswith(REMOVE_KEYS)]
    result_options = " ".join([*retained, *APPEND_TOKENS])
    result: list[str] = []
    for key, content, ending in lines:
        if key == "title":
            content = f"title {TITLE}"
        elif key == "options":
            content = f"options {result_options}"
        result.append(content + ending)
    rendered = "".join(result).encode()
    _, updated = parse_entry(rendered)
    for key in ("linux", "initrd", "fdtdir"):
        if updated[key] != fields[key]:
            fail(f"internal error: {key} artifact path changed")
    updated_tokens = updated["options"].split(" ")
    for key, matches in payload.items():
        if [token for token in updated_tokens if token.startswith(key)] != matches:
            fail(f"internal error: {key} payload token changed")
    for prefix, expected in (("console=", 2), ("rd.lvm.lv=", 3), ("sysrq_always_enabled=", 1)):
        if len([token for token in updated_tokens if token.startswith(prefix)]) != expected:
            fail(f"internal error: wrong number of {prefix} tokens")
    if tuple(updated_tokens[-len(APPEND_TOKENS) :]) != APPEND_TOKENS:
        fail("internal error: launch-contract suffix is not exact")
    return rendered, fields


def sparse_copy(source: Path, destination_fd: int) -> None:
    source_fd = os.open(source, os.O_RDONLY)
    try:
        size = os.fstat(source_fd).st_size
        os.ftruncate(destination_fd, size)
        position = 0
        try:
            while position < size:
                try:
                    data_offset = os.lseek(source_fd, position, os.SEEK_DATA)
                except OSError as error:
                    if error.errno == errno.ENXIO:
                        break
                    raise
                hole_offset = os.lseek(source_fd, data_offset, os.SEEK_HOLE)
                os.lseek(source_fd, data_offset, os.SEEK_SET)
                os.lseek(destination_fd, data_offset, os.SEEK_SET)
                remaining = min(hole_offset, size) - data_offset
                while remaining:
                    block = os.read(source_fd, min(1024 * 1024, remaining))
                    if not block:
                        fail("source image changed while being copied")
                    view = memoryview(block)
                    while view:
                        written = os.write(destination_fd, view)
                        view = view[written:]
                    remaining -= len(block)
                position = hole_offset
        except OSError as error:
            if error.errno not in (errno.EINVAL, errno.ENOTSUP, errno.ENOSYS):
                raise
            os.lseek(source_fd, 0, os.SEEK_SET)
            os.ftruncate(destination_fd, 0)
            os.lseek(destination_fd, 0, os.SEEK_SET)
            while block := os.read(source_fd, 1024 * 1024):
                if any(block):
                    view = memoryview(block)
                    while view:
                        written = os.write(destination_fd, view)
                        view = view[written:]
                else:
                    os.lseek(destination_fd, len(block), os.SEEK_CUR)
            os.ftruncate(destination_fd, size)
        os.fsync(destination_fd)
    finally:
        os.close(source_fd)


def checked_source(path_arg: str) -> tuple[Path, os.stat_result]:
    try:
        path = Path(path_arg).expanduser().resolve(strict=True)
        status = path.stat()
    except OSError as error:
        fail(f"cannot inspect source image: {error}")
    if not stat.S_ISREG(status.st_mode):
        fail(f"source image is not a regular file: {path}")
    return path, status


def checked_output(path_arg: str, source: Path) -> Path:
    path = Path(path_arg).expanduser().absolute()
    if os.path.lexists(path):
        fail(f"output exists; refusing to replace it: {path}")
    try:
        parent = path.parent.resolve(strict=True)
    except OSError as error:
        fail(f"cannot inspect output directory: {error}")
    if not parent.is_dir():
        fail(f"output parent is not a directory: {parent}")
    result = parent / path.name
    if result == source:
        fail("source and output paths are the same")
    return result


def e2fsck_readonly(e2fsck_path: str, image: Path) -> None:
    result = run([e2fsck_path, "-fn", str(image)])
    if result.returncode != 0:
        diagnostic = (result.stdout + result.stderr).decode("utf-8", "replace").strip()
        fail(f"e2fsck -fn rejected adapted image: {diagnostic or 'no diagnostic'}")


def adapt(source_arg: str, output_arg: str) -> tuple[Path, str]:
    debugfs_path = require_tool("debugfs")
    e2fsck_path = require_tool("e2fsck")
    source, source_status = checked_source(source_arg)
    output = checked_output(output_arg, source)
    source_hash = sha256_file(source)
    temporary: Path | None = None
    entry_temporary: Path | None = None
    try:
        descriptor, name = tempfile.mkstemp(prefix=f".{output.name}.tmp-", dir=output.parent)
        temporary = Path(name)
        try:
            sparse_copy(source, descriptor)
        finally:
            os.close(descriptor)
        name = entry_names(debugfs_path, temporary)[0]
        original = read_entry(debugfs_path, temporary, name)
        rendered, original_fields = adapt_entry(original)
        validate_artifacts(debugfs_path, temporary, original_fields)
        entry_descriptor, entry_name = tempfile.mkstemp(prefix="frankensargo-bls-", dir="/tmp")
        entry_temporary = Path(entry_name)
        with os.fdopen(entry_descriptor, "wb") as stream:
            stream.write(rendered)
            stream.flush()
            os.fsync(stream.fileno())
        debugfs(debugfs_path, temporary, f"rm {ENTRY_DIR}/{name}", write=True)
        debugfs(
            debugfs_path,
            temporary,
            f"write {entry_temporary} {ENTRY_DIR}/{name}",
            write=True,
        )
        if entry_names(debugfs_path, temporary) != [name]:
            fail("written image changed the Type #1 entry set")
        written = read_entry(debugfs_path, temporary, name)
        if written != rendered:
            fail("written Type #1 entry does not match the requested bytes")
        _, written_fields = parse_entry(written)
        if written_fields["title"] != TITLE:
            fail("written Type #1 title does not match the launch contract")
        for key in ("linux", "initrd", "fdtdir"):
            if written_fields[key] != original_fields[key]:
                fail(f"written Type #1 entry changed {key}")
        validate_artifacts(debugfs_path, temporary, written_fields)
        e2fsck_readonly(e2fsck_path, temporary)
        current_status = source.stat()
        stable = ("st_dev", "st_ino", "st_size", "st_mtime_ns", "st_ctime_ns")
        if any(getattr(current_status, field) != getattr(source_status, field) for field in stable):
            fail("source image metadata changed during adaptation")
        if sha256_file(source) != source_hash:
            fail("source image contents changed during adaptation")
        os.chmod(temporary, stat.S_IMODE(source_status.st_mode))
        with temporary.open("rb") as stream:
            os.fsync(stream.fileno())
        digest = sha256_file(temporary)
        try:
            os.link(temporary, output)
        except FileExistsError:
            fail(f"output appeared during adaptation; refusing to replace it: {output}")
        temporary.unlink()
        temporary = None
        return output, digest
    finally:
        if entry_temporary is not None:
            entry_temporary.unlink(missing_ok=True)
        if temporary is not None:
            temporary.unlink(missing_ok=True)


def parse_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--source", required=True, help="unmodified PocketBlue fedora_boot.raw")
    parser.add_argument("--output", required=True, help="fresh adapted raw-image path")
    return parser.parse_args(argv)


def main(argv: list[str]) -> int:
    args = parse_args(argv)
    try:
        output, digest = adapt(args.source, args.output)
    except (AdaptError, OSError, UnicodeDecodeError) as error:
        print(f"adapt-pocketblue-xbootldr: {error}", file=sys.stderr)
        return 1
    print(f"{digest}  {output}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
