+    fn add_dm(root: &Path, name: &str, uuid: &str, ro: &str) {
+        let path = root.join(name);
+        fs::create_dir_all(path.join("dm")).unwrap();
+        fs::write(path.join("dm/uuid"), format!("{uuid}\n")).unwrap();
+        fs::write(path.join("ro"), format!("{ro}\n")).unwrap();
+    }
