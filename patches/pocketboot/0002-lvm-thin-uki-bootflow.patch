diff --git a/src/bootflow/lvm_config.rs b/src/bootflow/lvm_config.rs
new file mode 100644
index 0000000000000000000000000000000000000000..9a1b8e1b41a670bf6bbd4a8b3e4bb5b4db8e8d20
--- /dev/null
+++ b/src/bootflow/lvm_config.rs
@@ -0,0 +1,350 @@
+//! Interim, explicit LVM allowlist supplied on the PocketBoot command line.
+//!
+//! This is deliberately narrower than the planned two-stage protocol.  It
+//! does not discover an anchor/meta manifest; callers must provide the exact VG
+//! UUID and every allowed physical partition UUID.
+//! It does not yet bind the LVM PV UUID for each partition; that belongs to the
+//! future signed/validated meta manifest tuple.
+
+use std::{
+    collections::{BTreeMap, BTreeSet},
+    fs, io,
+    path::{Path, PathBuf},
+};
+
+use crate::cmdline::KernelCommandLine;
+
+use super::{invalid_data, is_local_disk_name, is_virtual_block, read_trimmed, uevent_value};
+
+const VG_UUID_PARAM: &str = "pocketboot.vg_uuid";
+const PV_PARTUUID_PARAM: &str = "pocketboot.pv_partuuid";
+
+#[derive(Clone, Debug, Eq, PartialEq)]
+pub(super) struct LvmConfig {
+    vg_uuid: String,
+    pv_partuuids: Vec<String>,
+}
+
+impl LvmConfig {
+    pub(super) fn from_cmdline(cmdline: &KernelCommandLine) -> io::Result<Option<Self>> {
+        let vg_values = cmdline.parameter_values(VG_UUID_PARAM).collect::<Vec<_>>();
+        let pv_values = cmdline
+            .parameter_values(PV_PARTUUID_PARAM)
+            .collect::<Vec<_>>();
+        if vg_values.is_empty() && pv_values.is_empty() {
+            return Ok(None);
+        }
+        if vg_values.is_empty() || pv_values.is_empty() {
+            return Err(invalid_data(format!(
+                "{VG_UUID_PARAM} and {PV_PARTUUID_PARAM} must be supplied together"
+            )));
+        }
+        if vg_values.len() != 1 {
+            return Err(invalid_data(format!(
+                "exactly one {VG_UUID_PARAM} is required"
+            )));
+        }
+        let vg_uuid = vg_values[0]
+            .filter(|value| !value.is_empty())
+            .ok_or_else(|| invalid_data(format!("{VG_UUID_PARAM} must have a value")))?;
+        validate_lvm_uuid(vg_uuid)?;
+
+        let mut seen = BTreeSet::new();
+        let mut pv_partuuids = Vec::with_capacity(pv_values.len());
+        for value in pv_values {
+            let value = value
+                .filter(|value| !value.is_empty())
+                .ok_or_else(|| invalid_data(format!("{PV_PARTUUID_PARAM} must have a value")))?;
+            let normalized = normalize_gpt_partuuid(value)?;
+            if !seen.insert(normalized.clone()) {
+                return Err(invalid_data(format!(
+                    "duplicate {PV_PARTUUID_PARAM}: {value}"
+                )));
+            }
+            pv_partuuids.push(normalized);
+        }
+
+        Ok(Some(Self {
+            vg_uuid: vg_uuid.to_string(),
+            pv_partuuids,
+        }))
+    }
+
+    pub(super) fn vg_uuid(&self) -> &str {
+        &self.vg_uuid
+    }
+
+    pub(super) fn pv_partuuids(&self) -> &[String] {
+        &self.pv_partuuids
+    }
+
+    pub(super) fn resolve_pv_devices(
+        &self,
+        sys_block_root: &Path,
+        dev_root: &Path,
+    ) -> io::Result<Vec<PathBuf>> {
+        let requested = self.pv_partuuids.iter().cloned().collect::<BTreeSet<_>>();
+        let mut matches = BTreeMap::<String, Vec<PathBuf>>::new();
+        let mut disks = fs::read_dir(sys_block_root)?.collect::<Result<Vec<_>, _>>()?;
+        disks.sort_by_key(fs::DirEntry::file_name);
+
+        for disk in disks {
+            let disk_name = disk.file_name();
+            let Some(disk_name) = disk_name.to_str() else {
+                continue;
+            };
+            if !is_local_disk_name(disk_name)
+                || is_virtual_block(&disk.path())
+                || read_trimmed(disk.path().join("removable")).as_deref() != Some("0")
+                || !dev_root.join(disk_name).exists()
+            {
+                continue;
+            }
+            let disk_path = disk.path();
+            let mut partitions = fs::read_dir(&disk_path)?.collect::<Result<Vec<_>, _>>()?;
+            partitions.sort_by_key(fs::DirEntry::file_name);
+            for partition in partitions {
+                let sysfs_path = partition.path();
+                if !sysfs_path.join("partition").is_file() {
+                    continue;
+                }
+                let Some(partuuid) = uevent_value(sysfs_path.join("uevent"), "PARTUUID") else {
+                    continue;
+                };
+                let Ok(partuuid) = normalize_gpt_partuuid(&partuuid) else {
+                    continue;
+                };
+                if !requested.contains(&partuuid) {
+                    continue;
+                }
+                let partition_name = partition.file_name();
+                let dev_path = dev_root.join(&partition_name);
+                if !dev_path.exists() {
+                    return Err(io::Error::new(
+                        io::ErrorKind::NotFound,
+                        format!(
+                            "allowed PV partition {partuuid} has no device node {}",
+                            dev_path.display()
+                        ),
+                    ));
+                }
+                matches.entry(partuuid).or_default().push(dev_path);
+            }
+        }
+
+        self.pv_partuuids
+            .iter()
+            .map(
+                |partuuid| match matches.remove(partuuid).unwrap_or_default().as_slice() {
+                    [] => Err(io::Error::new(
+                        io::ErrorKind::NotFound,
+                        format!("allowed PV PARTUUID was not found locally: {partuuid}"),
+                    )),
+                    [device] => Ok(device.clone()),
+                    devices => Err(invalid_data(format!(
+                        "allowed PV PARTUUID {partuuid} is ambiguous across {} devices",
+                        devices.len()
+                    ))),
+                },
+            )
+            .collect()
+    }
+}
+
+fn validate_lvm_uuid(value: &str) -> io::Result<()> {
+    const GROUPS: [usize; 7] = [6, 4, 4, 4, 4, 4, 6];
+    let groups = value.split('-').collect::<Vec<_>>();
+    if groups.len() != GROUPS.len()
+        || groups.iter().zip(GROUPS).any(|(group, len)| {
+            group.len() != len || !group.bytes().all(|b| b.is_ascii_alphanumeric())
+        })
+    {
+        return Err(invalid_data(format!("malformed {VG_UUID_PARAM}: {value}")));
+    }
+    Ok(())
+}
+
+fn normalize_gpt_partuuid(value: &str) -> io::Result<String> {
+    const GROUPS: [usize; 5] = [8, 4, 4, 4, 12];
+    let groups = value.split('-').collect::<Vec<_>>();
+    if groups.len() != GROUPS.len()
+        || groups
+            .iter()
+            .zip(GROUPS)
+            .any(|(group, len)| group.len() != len || !group.bytes().all(|b| b.is_ascii_hexdigit()))
+    {
+        return Err(invalid_data(format!(
+            "malformed {PV_PARTUUID_PARAM}: {value}"
+        )));
+    }
+    Ok(value.to_ascii_lowercase())
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+    use std::{
+        sync::atomic::{AtomicU64, Ordering},
+        time::{SystemTime, UNIX_EPOCH},
+    };
+
+    const VG_UUID: &str = "ABCDEF-1234-5678-9abc-def0-1234-567890";
+    const PARTUUID_A: &str = "11111111-2222-3333-4444-555555555555";
+    const PARTUUID_B: &str = "aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee";
+    const PARTUUID_C: &str = "01234567-89ab-cdef-0123-456789abcdef";
+    static NEXT: AtomicU64 = AtomicU64::new(0);
+
+    #[test]
+    fn absent_config_is_disabled_and_valid_config_preserves_pv_order() {
+        assert_eq!(
+            LvmConfig::from_cmdline(&KernelCommandLine::parse("quiet")).unwrap(),
+            None
+        );
+        let cmdline = KernelCommandLine::parse(&format!(
+            "{VG_UUID_PARAM}={VG_UUID} {PV_PARTUUID_PARAM}={PARTUUID_B} {PV_PARTUUID_PARAM}={PARTUUID_A}"
+        ));
+        let config = LvmConfig::from_cmdline(&cmdline).unwrap().unwrap();
+        assert_eq!(config.vg_uuid(), VG_UUID);
+        assert_eq!(config.pv_partuuids(), [PARTUUID_B, PARTUUID_A]);
+    }
+
+    #[test]
+    fn interim_binding_contains_only_vg_and_partition_uuids() {
+        let config = config(&[PARTUUID_A]);
+
+        assert_eq!(config.vg_uuid(), VG_UUID);
+        assert_eq!(config.pv_partuuids(), [PARTUUID_A]);
+        // PV UUID binding is intentionally deferred to the anchor/meta
+        // manifest protocol; no inferred or scanned PV identity is stored.
+    }
+
+    #[test]
+    fn rejects_partial_empty_duplicate_and_malformed_config() {
+        for text in [
+            format!("{VG_UUID_PARAM}={VG_UUID}"),
+            format!("{PV_PARTUUID_PARAM}={PARTUUID_A}"),
+            format!("{VG_UUID_PARAM}= {PV_PARTUUID_PARAM}={PARTUUID_A}"),
+            format!("{VG_UUID_PARAM}={VG_UUID} {PV_PARTUUID_PARAM}="),
+            format!(
+                "{VG_UUID_PARAM}={VG_UUID} {VG_UUID_PARAM}={VG_UUID} {PV_PARTUUID_PARAM}={PARTUUID_A}"
+            ),
+            format!(
+                "{VG_UUID_PARAM}={VG_UUID} {PV_PARTUUID_PARAM}={PARTUUID_A} {PV_PARTUUID_PARAM}={PARTUUID_A}"
+            ),
+            format!("{VG_UUID_PARAM}=wrong {PV_PARTUUID_PARAM}={PARTUUID_A}"),
+            format!("{VG_UUID_PARAM}={VG_UUID} {PV_PARTUUID_PARAM}=wrong"),
+        ] {
+            assert!(
+                LvmConfig::from_cmdline(&KernelCommandLine::parse(&text)).is_err(),
+                "accepted {text}"
+            );
+        }
+    }
+
+    #[test]
+    fn resolves_only_exact_local_physical_partition_uuids() {
+        let temp = TestDir::new();
+        let sys = temp.path.join("sys-block");
+        let dev = temp.path.join("dev");
+        fs::create_dir_all(&sys).unwrap();
+        fs::create_dir_all(&dev).unwrap();
+        add_disk(&sys, &dev, "sda", &[("sda1", PARTUUID_A)]);
+        add_disk(&sys, &dev, "mmcblk0", &[("mmcblk0p2", PARTUUID_B)]);
+        add_disk(
+            &sys,
+            &dev,
+            "dm-0",
+            &[("dm-0p1", "99999999-9999-9999-9999-999999999999")],
+        );
+        let config = config(&[PARTUUID_B, PARTUUID_A]);
+
+        let devices = config.resolve_pv_devices(&sys, &dev).unwrap();
+
+        assert_eq!(devices, [dev.join("mmcblk0p2"), dev.join("sda1")]);
+    }
+
+    #[test]
+    fn rejects_missing_and_ambiguous_partuuid_matches() {
+        let temp = TestDir::new();
+        let sys = temp.path.join("sys-block");
+        let dev = temp.path.join("dev");
+        fs::create_dir_all(&sys).unwrap();
+        fs::create_dir_all(&dev).unwrap();
+        add_disk(&sys, &dev, "sda", &[("sda1", PARTUUID_A)]);
+        assert!(
+            config(&[PARTUUID_B])
+                .resolve_pv_devices(&sys, &dev)
+                .is_err()
+        );
