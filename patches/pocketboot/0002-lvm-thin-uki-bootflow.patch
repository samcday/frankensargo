+        let bytes = fs::read(output).unwrap();
+        let entries = parse_newc(&bytes);
+        assert!(!entries.contains_key("sbin/lvm.static"));
+        assert!(!entries.contains_key("etc/lvm/lvm.conf"));
+        assert!(!entries.contains_key("usr/sbin/thin_check"));
