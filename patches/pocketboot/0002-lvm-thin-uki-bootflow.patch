+        add_disk(&sys, &dev, "sdb", &[("sdb1", PARTUUID_A)]);
+        let error = config(&[PARTUUID_A])
+            .resolve_pv_devices(&sys, &dev)
+            .unwrap_err();
+        assert!(error.to_string().contains("ambiguous"));
+    }
+
+    #[test]
+    fn rejects_removable_parent_disks() {
+        let temp = TestDir::new();
+        let sys = temp.path.join("sys-block");
+        let dev = temp.path.join("dev");
+        fs::create_dir_all(&sys).unwrap();
+        fs::create_dir_all(&dev).unwrap();
+        add_disk(&sys, &dev, "sdc", &[("sdc1", PARTUUID_C)]);
+        fs::write(sys.join("sdc/removable"), b"1\n").unwrap();
+
+        let error = config(&[PARTUUID_C])
+            .resolve_pv_devices(&sys, &dev)
+            .unwrap_err();
+
+        assert_eq!(error.kind(), io::ErrorKind::NotFound);
+    }
+
+    fn config(partuuids: &[&str]) -> LvmConfig {
+        LvmConfig {
+            vg_uuid: VG_UUID.to_string(),
+            pv_partuuids: partuuids.iter().map(|value| (*value).to_string()).collect(),
+        }
+    }
+
+    fn add_disk(sys: &Path, dev: &Path, disk: &str, partitions: &[(&str, &str)]) {
+        let disk_path = sys.join(disk);
+        fs::create_dir_all(&disk_path).unwrap();
+        fs::write(disk_path.join("removable"), b"0\n").unwrap();
+        fs::write(dev.join(disk), b"").unwrap();
+        for (partition, partuuid) in partitions {
+            let path = disk_path.join(partition);
+            fs::create_dir_all(&path).unwrap();
+            fs::write(path.join("partition"), b"1\n").unwrap();
+            fs::write(path.join("uevent"), format!("PARTUUID={partuuid}\n")).unwrap();
+            fs::write(dev.join(partition), b"").unwrap();
+        }
+    }
+
+    struct TestDir {
+        path: PathBuf,
+    }
+
+    impl TestDir {
+        fn new() -> Self {
+            let serial = NEXT.fetch_add(1, Ordering::Relaxed);
+            let nonce = SystemTime::now()
+                .duration_since(UNIX_EPOCH)
+                .unwrap()
+                .as_nanos();
+            let path = std::env::temp_dir().join(format!(
+                "pocketboot-lvm-config-{}-{serial}-{nonce}",
+                std::process::id()
+            ));
+            fs::create_dir(&path).unwrap();
+            Self { path }
+        }
+    }
+
+    impl Drop for TestDir {
+        fn drop(&mut self) {
+            let _ = fs::remove_dir_all(&self.path);
+        }
+    }
+}
