+fn read_uki_file_bounded(root: &Path, path: &Path) -> io::Result<Vec<u8>> {
+    verify_beneath_without_symlinks(root, path)?;
+    let file = OpenOptions::new()
+        .read(true)
+        .custom_flags(libc::O_NOFOLLOW | libc::O_CLOEXEC)
+        .open(path)
+        .map_err(|err| io::Error::new(err.kind(), format!("open UKI {}: {err}", path.display())))?;
+    let metadata = file
+        .metadata()
+        .map_err(|err| io::Error::new(err.kind(), format!("stat UKI {}: {err}", path.display())))?;
+    if !metadata.file_type().is_file() {
+        return Err(invalid_data(format!(
+            "UKI path is not a regular file: {}",
+            path.display()
+        )));
+    }
+    if metadata.len() > MAX_UKI_FILE_BYTES {
+        return Err(uki_size_limit_error(path, metadata.len()));
+    }
+
+    let initial_capacity = usize::try_from(metadata.len().min(1024 * 1024))
+        .expect("bounded initial UKI capacity fits usize");
+    let mut data = Vec::with_capacity(initial_capacity);
+    file.take(MAX_UKI_FILE_BYTES + 1)
+        .read_to_end(&mut data)
+        .map_err(|err| io::Error::new(err.kind(), format!("read UKI {}: {err}", path.display())))?;
+    if data.len() as u64 > MAX_UKI_FILE_BYTES {
+        return Err(uki_size_limit_error(path, data.len() as u64));
+    }
+    Ok(data)
+}
+
+fn uki_size_limit_error(path: &Path, bytes: u64) -> io::Error {
+    invalid_data(format!(
+        "UKI {} is {bytes} bytes, exceeding the 256 MiB logical file limit",
+        path.display()
+    ))
+}
+
+fn verify_beneath_without_symlinks(root: &Path, path: &Path) -> io::Result<()> {
+    let relative = path.strip_prefix(root).map_err(|_| {
+        invalid_data(format!(
+            "boot path escapes mount root {}: {}",
+            root.display(),
+            path.display()
+        ))
+    })?;
+    let components = relative.components().collect::<Vec<_>>();
+    if components.is_empty() {
+        return Err(invalid_data(format!(
+            "boot path resolves to mount root: {}",
+            path.display()
+        )));
+    }
+
+    let root_metadata = fs::symlink_metadata(root).map_err(|err| {
+        io::Error::new(
+            err.kind(),
+            format!("stat boot mount root {}: {err}", root.display()),
+        )
+    })?;
+    if root_metadata.file_type().is_symlink() || !root_metadata.file_type().is_dir() {
+        return Err(invalid_data(format!(
+            "boot mount root is not a real directory: {}",
+            root.display()
+        )));
+    }
+    let canonical_root = fs::canonicalize(root).map_err(|err| {
+        io::Error::new(
+            err.kind(),
+            format!("resolve boot mount root {}: {err}", root.display()),
+        )
+    })?;
+
+    let mut current = root.to_path_buf();
+    for (index, component) in components.iter().enumerate() {
+        let Component::Normal(component) = component else {
+            return Err(invalid_data(format!(
+                "boot path is not normalized beneath {}: {}",
+                root.display(),
+                path.display()
+            )));
+        };
+        current.push(component);
+        let metadata = fs::symlink_metadata(&current).map_err(|err| {
+            io::Error::new(
+                err.kind(),
+                format!("stat boot path {}: {err}", current.display()),
+            )
+        })?;
+        if metadata.file_type().is_symlink() {
+            return Err(invalid_data(format!(
+                "boot path traverses a symlink: {}",
+                current.display()
+            )));
+        }
+        if index + 1 < components.len() && !metadata.file_type().is_dir() {
+            return Err(invalid_data(format!(
+                "boot path component is not a directory: {}",
+                current.display()
+            )));
+        }
+    }
+
+    let canonical_path = fs::canonicalize(path).map_err(|err| {
+        io::Error::new(
+            err.kind(),
+            format!("resolve boot path {}: {err}", path.display()),
+        )
+    })?;
+    if !canonical_path.starts_with(&canonical_root) {
+        return Err(invalid_data(format!(
+            "boot path escapes mount root {}: {}",
+            canonical_root.display(),
+            canonical_path.display()
+        )));
+    }
+    Ok(())
+}
