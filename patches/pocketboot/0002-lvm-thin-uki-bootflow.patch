+fn direct_uki_entries_for_file(
+    partition: &BootPartitionCandidate,
+    root: &Path,
+    path: &Path,
+) -> io::Result<Vec<BootEntry>> {
+    let data = read_uki_file_bounded(root, path)?;
+    let Some(uki) = uki::Uki::parse(&data)? else {
+        return Err(invalid_data("candidate is not PE/COFF"));
+    };
+    let filename = path
+        .file_name()
+        .map(|name| name.to_string_lossy().into_owned())
+        .ok_or_else(|| invalid_data(format!("UKI path {} has no filename", path.display())))?;
+
+    uki.profiles()
+        .iter()
+        .map(|profile| {
+            let profile_index = profile.index();
+            Ok(BootEntry {
+                id: format!("uki:{filename}@{profile_index}"),
+                title: Some(uki_profile_title(profile, &filename)?),
+                version: uki_profile_version(profile)?,
+                architecture: Some("AA64".to_string()),
+                source: path.to_path_buf(),
+                role: partition.role,
+                disk: partition.disk.clone(),
+                partition: partition.partition.clone(),
+                preferred: false,
+                payload: BootPayload::Uki {
+                    root: root.to_path_buf(),
+                    path: path.to_path_buf(),
+                    profile: profile_index,
+                    discovered_cmdline: profile.cmdline().unwrap_or_default().to_string(),
+                    cmdline_override: None,
+                },
+                automatic_boot: profile_index == 0,
+                boot_order: u32::try_from(profile_index)
+                    .map_err(|_| invalid_data("UKI profile index exceeds boot ordering range"))?,
+            })
+        })
+        .collect()
+}
