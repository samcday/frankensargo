+    pub(super) fn root_compatible_strings(dtb: &[u8]) -> io::Result<Vec<String>> {
+        let header = Header::parse(dtb)?;
+        let struct_block = checked_slice(
+            dtb,
+            header.off_dt_struct,
+            header.size_dt_struct,
+            "DTB structure block",
+        )?;
+        let strings = checked_slice(
+            dtb,
+            header.off_dt_strings,
+            header.size_dt_strings,
+            "DTB strings block",
+        )?;
+        let mut cursor = 0usize;
+        let mut depth = 0usize;
+        let mut saw_root = false;
+        let mut compatible = None;
+
+        loop {
+            let token = read_be32(struct_block, cursor)?;
+            cursor += 4;
+            match token {
+                FDT_BEGIN_NODE => {
+                    let name_end = find_nul(struct_block, cursor)?;
+                    let name = &struct_block[cursor..name_end];
+                    cursor = align_usize(name_end + 1, 4)?;
+                    if cursor > struct_block.len() {
+                        return invalid_data("DTB node name extends past structure block");
+                    }
+                    if depth == 0 {
+                        if saw_root {
+                            return invalid_data("DTB structure has multiple root nodes");
+                        }
+                        if !name.is_empty() {
+                            return invalid_data("DTB root node name is not empty");
+                        }
+                        saw_root = true;
+                    }
+                    depth += 1;
+                }
+                FDT_END_NODE => {
+                    if depth == 0 {
+                        return invalid_data("DTB structure has too many END_NODE tokens");
+                    }
+                    depth -= 1;
+                }
+                FDT_PROP => {
+                    if depth == 0 {
+                        return invalid_data("DTB property appears outside the root node");
+                    }
+                    let parts = property_parts(struct_block, cursor)?;
+                    let name = string_at(strings, parts.nameoff).ok_or_else(|| {
+                        invalid_data_error(format!(
+                            "DTB property name offset {} is out of range",
+                            parts.nameoff
+                        ))
+                    })?;
+                    if depth == 1 && name == b"compatible" {
+                        if compatible.is_some() {
+                            return invalid_data("DTB root has duplicate compatible properties");
+                        }
+                        compatible = Some(parse_string_list(
+                            &struct_block[parts.value_start..parts.value_end],
+                            "DTB root compatible",
+                        )?);
+                    }
+                    cursor = parts.next;
+                }
+                FDT_NOP => {}
+                FDT_END => {
+                    if !saw_root {
+                        return invalid_data("DTB structure has no root node");
+                    }
+                    if depth != 0 {
+                        return invalid_data("DTB structure ended before all nodes were closed");
+                    }
+                    return Ok(compatible.unwrap_or_default());
+                }
+                _ => return invalid_data(format!("DTB has unknown structure token {token}")),
+            }
+        }
+    }
