+    fn assert_devices(invocation: &CommandInvocation, expected: &[PathBuf]) {
+        let actual = invocation
+            .args
+            .windows(2)
+            .filter(|pair| pair[0] == "--devices")
+            .map(|pair| PathBuf::from(&pair[1]))
+            .collect::<Vec<_>>();
+        assert_eq!(actual, expected);
+    }
+
+    struct RecordingRunner {
+        calls: RefCell<Vec<CommandInvocation>>,
+        outputs: RefCell<VecDeque<CommandOutput>>,
+        effects: RefCell<VecDeque<Option<RunnerEffect>>>,
+    }
+
+    struct DmFixture {
+        root: PathBuf,
+        name: String,
+        uuid: String,
+        ro: String,
+    }
+
+    enum RunnerEffect {
+        AddDm(DmFixture),
+        AddDms(Vec<DmFixture>),
+    }
+
+    impl RunnerEffect {
+        fn apply(self) {
+            match self {
+                Self::AddDm(dm) => add_dm(&dm.root, &dm.name, &dm.uuid, &dm.ro),
+                Self::AddDms(devices) => {
+                    for dm in devices {
+                        add_dm(&dm.root, &dm.name, &dm.uuid, &dm.ro);
+                    }
+                }
+            }
+        }
+    }
+
+    impl RecordingRunner {
+        fn success(report: Vec<u8>, activations: usize) -> Self {
+            let mut outputs = VecDeque::from([success_output(report)]);
+            outputs.extend((0..activations).map(|_| success_output(Vec::new())));
+            let effects = (0..outputs.len()).map(|_| None).collect();
+            Self {
+                calls: RefCell::new(Vec::new()),
+                outputs: RefCell::new(outputs),
+                effects: RefCell::new(effects),
+            }
+        }
+
+        fn report_then_dm(report: Vec<u8>, root: &Path, name: &str, uuid: &str, ro: &str) -> Self {
+            Self::with_steps([
+                (success_output(report), None),
+                (
+                    success_output(Vec::new()),
+                    Some(RunnerEffect::AddDm(DmFixture {
+                        root: root.to_path_buf(),
+                        name: name.to_string(),
+                        uuid: uuid.to_string(),
+                        ro: ro.to_string(),
+                    })),
+                ),
+            ])
+        }
+
+        fn candidate_then_effect(effect: RunnerEffect) -> Self {
+            Self::with_steps([
+                (success_output(candidate_report()), None),
+                (success_output(Vec::new()), Some(effect)),
+                (success_output(Vec::new()), None),
+            ])
+        }
+
+        fn with_steps(
+            steps: impl IntoIterator<Item = (CommandOutput, Option<RunnerEffect>)>,
+        ) -> Self {
+            let (outputs, effects) = steps.into_iter().unzip();
+            Self {
+                calls: RefCell::new(Vec::new()),
+                outputs: RefCell::new(outputs),
+                effects: RefCell::new(effects),
+            }
+        }
+    }
+
+    fn success_output(stdout: Vec<u8>) -> CommandOutput {
+        CommandOutput {
+            success: true,
+            stdout,
+            stderr: Vec::new(),
+        }
+    }
+
+    fn failure_output(stderr: &str) -> CommandOutput {
+        CommandOutput {
+            success: false,
+            stdout: Vec::new(),
+            stderr: stderr.as_bytes().to_vec(),
+        }
+    }
+
+    impl CommandRunner for RecordingRunner {
+        fn run(&self, invocation: &CommandInvocation) -> Result<CommandOutput> {
+            self.calls.borrow_mut().push(invocation.clone());
+            let output = self
+                .outputs
+                .borrow_mut()
+                .pop_front()
+                .ok_or_else(|| "unexpected command".to_string())?;
+            if let Some(effect) = self.effects.borrow_mut().pop_front().flatten() {
+                effect.apply();
+            }
+            Ok(output)
+        }
+    }
+
+    struct TempDir {
+        path: PathBuf,
+    }
+
+    impl TempDir {
+        fn new() -> Self {
+            let mut path = std::env::temp_dir();
+            let nonce = SystemTime::now()
+                .duration_since(UNIX_EPOCH)
+                .unwrap()
+                .as_nanos();
+            path.push(format!(
+                "pocketboot-lvm-test-{}-{nonce}",
+                std::process::id()
+            ));
+            fs::create_dir(&path).unwrap();
+            Self { path }
+        }
+    }
+
+    impl Drop for TempDir {
+        fn drop(&mut self) {
+            let _ = fs::remove_dir_all(&self.path);
+        }
+    }
+}
