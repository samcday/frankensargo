+        assert_eq!(entries["sbin"].mode, 0o040755);
+        assert_eq!(entries["lib/ld-musl-aarch64.so.1"].mode, 0o100755);
+        assert_eq!(entries["lib/libc.musl-aarch64.so.1"].mode, 0o120777);
