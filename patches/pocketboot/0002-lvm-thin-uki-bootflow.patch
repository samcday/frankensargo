+    #[derive(Debug)]
+    struct ParsedEntry {
+        mode: u32,
+        contents: Vec<u8>,
+    }
+
+    fn parse_newc(bytes: &[u8]) -> BTreeMap<String, ParsedEntry> {
+        let mut entries = BTreeMap::new();
+        let mut offset = 0usize;
+        loop {
+            let header = &bytes[offset..offset + 110];
+            assert_eq!(&header[..6], b"070701");
+            let mode = parse_hex(&header[14..22]);
+            let size = parse_hex(&header[54..62]) as usize;
+            let namesize = parse_hex(&header[94..102]) as usize;
+            offset += 110;
+            let name = std::str::from_utf8(&bytes[offset..offset + namesize - 1])
+                .unwrap()
+                .to_string();
+            offset = align4(offset + namesize);
+            let contents = bytes[offset..offset + size].to_vec();
+            offset = align4(offset + size);
+            if name == "TRAILER!!!" {
+                break;
+            }
+            entries.insert(name, ParsedEntry { mode, contents });
+        }
+        entries
+    }
+
+    fn parse_hex(bytes: &[u8]) -> u32 {
+        u32::from_str_radix(std::str::from_utf8(bytes).unwrap(), 16).unwrap()
+    }
+
+    fn align4(value: usize) -> usize {
+        (value + 3) & !3
+    }
