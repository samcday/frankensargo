+++ b/src/lvm.rs
@@ -0,0 +1,1292 @@
+//! Narrow, read-mostly LVM discovery for explicitly allowed physical devices.
+//!
+//! This module deliberately does not enumerate candidate PVs, modify LVM
+//! metadata, or provide a general LVM command interface.  The sole mutation is
+//! activating an individually selected LV.  `/etc/lvm/lvm.conf` constrains LVs
+//! carrying one of the PocketBoot role tags to read-only activation.
+
+// The public runtime entrypoint intentionally lands before bootflow calls it.
+#![allow(dead_code)]
+
+use std::{
+    collections::{BTreeMap, BTreeSet},
+    ffi::OsString,
+    fs,
+    path::{Component, Path, PathBuf},
+    process::{Command, Stdio},
+};
+
+use serde::Deserialize;
+
+use crate::Result;
+
+// Alpine's static multicall binary must retain this basename. When invoked as
+// `lvm`, it dispatches to the configured dynamic /sbin/lvm instead.
+const LVM: &str = "/sbin/lvm.static";
+const SYS_BLOCK: &str = "/sys/block";
+const LVM_SYSTEM_DIR: &str = "/etc/lvm";
+const VG_TAG: &str = "pocketboot.vg.v1";
+const META_TAG: &str = "pocketboot.meta.v1";
+const BOOTFS_TAG: &str = "pocketboot.bootfs.v1";
+const DISK_TAG: &str = "pocketboot.disk.v1";
+const REPORT_FIELDS: &str = "vg_name,lv_name,vg_uuid,lv_uuid,vg_tags,lv_tags,lv_active";
+
+pub(crate) fn prepare_runtime_directories() -> Result<()> {
+    for directory in ["/run/lvm", "/run/lock/lvm", "/dev/mapper"] {
+        fs::create_dir_all(directory).map_err(|err| format!("create {directory}: {err}"))?;
+    }
+    Ok(())
+}
+
+/// The semantic role declared by the LV's one PocketBoot role tag.
+#[derive(Clone, Copy, Debug, Eq, Ord, PartialEq, PartialOrd)]
+pub(crate) enum LogicalVolumeRole {
+    Meta,
+    BootFs,
+    Disk,
+}
+
+impl LogicalVolumeRole {
+    fn tag(self) -> &'static str {
+        match self {
+            Self::Meta => META_TAG,
+            Self::BootFs => BOOTFS_TAG,
+            Self::Disk => DISK_TAG,
+        }
+    }
+
+    fn from_tags(tags: &[String]) -> Result<Option<Self>> {
+        let roles = tags
+            .iter()
+            .filter_map(|tag| match tag.as_str() {
+                META_TAG => Some(Self::Meta),
+                BOOTFS_TAG => Some(Self::BootFs),
+                DISK_TAG => Some(Self::Disk),
+                _ => None,
+            })
+            .collect::<Vec<_>>();
+
+        match roles.as_slice() {
+            [] => Ok(None),
+            [role] => Ok(Some(*role)),
+            _ => Err(format!(
+                "LVM logical volume has multiple PocketBoot role tags: {}",
+                tags.join(",")
+            )),
+        }
+    }
+}
+
+/// A PocketBoot-tagged LV whose top-level device-mapper node is read-only.
+///
+/// `lv_uuid` is the persistent identity. `device` is only the device node for
+/// this boot and must not be persisted as identity.
+#[derive(Clone, Debug, Eq, PartialEq)]
+pub(crate) struct ActivatedLogicalVolume {
+    pub(crate) role: LogicalVolumeRole,
+    pub(crate) vg_name: String,
+    pub(crate) lv_name: String,
+    pub(crate) vg_uuid: String,
+    pub(crate) lv_uuid: String,
+    pub(crate) device: PathBuf,
+}
+
+/// Discover and activate PocketBoot-tagged LVs on exactly `physical_devices`.
+///
+/// An empty list is rejected rather than permitting LVM to scan every device.
+pub(crate) fn activate_tagged(
+    expected_vg_uuid: &str,
+    physical_devices: &[PathBuf],
+) -> Result<Vec<ActivatedLogicalVolume>> {
+    activate_tagged_with(
+        &SystemCommandRunner,
+        Path::new(SYS_BLOCK),
+        expected_vg_uuid,
+        physical_devices,
+    )
+}
+
+#[derive(Clone, Debug, Eq, PartialEq)]
+pub(crate) struct CommandInvocation {
+    pub(crate) program: PathBuf,
+    pub(crate) args: Vec<OsString>,
+}
+
+#[derive(Clone, Debug, Eq, PartialEq)]
+pub(crate) struct CommandOutput {
+    pub(crate) success: bool,
+    pub(crate) stdout: Vec<u8>,
+    pub(crate) stderr: Vec<u8>,
+}
+
+/// Injectable command boundary used to test every LVM argv without privileges.
+pub(crate) trait CommandRunner {
+    fn run(&self, invocation: &CommandInvocation) -> Result<CommandOutput>;
+}
+
+struct SystemCommandRunner;
+
+impl CommandRunner for SystemCommandRunner {
+    fn run(&self, invocation: &CommandInvocation) -> Result<CommandOutput> {
+        let output = Command::new(&invocation.program)
+            .args(&invocation.args)
+            .env_clear()
+            .env("HOME", "/")
+            .env("PATH", "/sbin:/usr/sbin:/bin:/usr/bin")
+            .env("LC_ALL", "C")
+            .env("LVM_SYSTEM_DIR", LVM_SYSTEM_DIR)
+            .stdin(Stdio::null())
+            .output()
+            .map_err(|err| format!("run {}: {err}", invocation.program.display()))?;
+        Ok(CommandOutput {
+            success: output.status.success(),
+            stdout: output.stdout,
+            stderr: output.stderr,
+        })
+    }
+}
+
+/// Testable form of [`activate_tagged`] with injected process and sysfs access.
+pub(crate) fn activate_tagged_with<R: CommandRunner>(
+    runner: &R,
+    sys_block: &Path,
+    expected_vg_uuid: &str,
+    physical_devices: &[PathBuf],
+) -> Result<Vec<ActivatedLogicalVolume>> {
+    validate_physical_devices(physical_devices)?;
+    let expected_vg_uuid = LvmUuid::parse("expected VG", expected_vg_uuid.to_string())?;
+
+    let report = run_checked(runner, report_invocation(physical_devices)?)?;
+    let mut candidates = parse_candidates(&report, &expected_vg_uuid)?;
+    candidates.sort_by(|left, right| left.lv_uuid.compact.cmp(&right.lv_uuid.compact));
+    ensure_not_preexisting(sys_block, &candidates)?;
+
+    let mut activated_candidates = Vec::new();
+    for candidate in candidates {
+        match run_checked(runner, activation_invocation(physical_devices, &candidate)?) {
+            Ok(_) => {
+                tracing::debug!(
+                    vg = %candidate.vg_name,
+                    lv = %candidate.lv_name,
+                    lv_uuid = %candidate.lv_uuid.display,
+                    "requested read-only-policy LVM activation"
+                );
+                activated_candidates.push(candidate);
+            }
+            Err(err) => tracing::warn!(
+                vg = %candidate.vg_name,
+                lv = %candidate.lv_name,
+                lv_uuid = %candidate.lv_uuid.display,
+                error = %err,
+                "omitting LV after activation failure"
+            ),
+        }
+    }
+
+    let activated = match map_activated(sys_block, activated_candidates.clone()) {
+        Ok(activated) => activated,
+        Err(verification_error) => {
+            for candidate in activated_candidates.iter().rev() {
+                match deactivation_invocation(physical_devices, candidate)
+                    .and_then(|invocation| run_checked(runner, invocation))
+                {
+                    Ok(_) => tracing::warn!(
+                        vg = %candidate.vg_name,
+                        lv = %candidate.lv_name,
+                        lv_uuid = %candidate.lv_uuid.display,
+                        "rolled back LVM activation after verification failure"
+                    ),
+                    Err(err) => tracing::error!(
+                        vg = %candidate.vg_name,
+                        lv = %candidate.lv_name,
+                        lv_uuid = %candidate.lv_uuid.display,
+                        error = %err,
+                        "failed to roll back LVM activation after verification failure"
+                    ),
+                }
+            }
+            return Err(verification_error);
+        }
+    };
+    if !activated.is_empty() {
+        // A read-only top-level thin LV still requires its thin-pool dependency
+        // to be active.  Device-mapper may write that pool's metadata; this
+        // check intentionally promises only that the exposed LV is read-only.
+        tracing::info!(
+            count = activated.len(),
+            "verified read-only top-level LVM devices; thin-pool dependencies may still write metadata"
+        );
+    }
+    Ok(activated)
+}
+
+fn report_invocation(physical_devices: &[PathBuf]) -> Result<CommandInvocation> {
+    let mut args = vec![
+        OsString::from("lvs"),
+        OsString::from("--readonly"),
+        OsString::from("--reportformat"),
+        OsString::from("json_std"),
+        OsString::from("--options"),
+        OsString::from(REPORT_FIELDS),
+        OsString::from("--nohints"),
+        OsString::from("--nolocking"),
+    ];
+    append_devices(&mut args, physical_devices)?;
+    Ok(CommandInvocation {
+        program: PathBuf::from(LVM),
+        args,
+    })
+}
+
+fn activation_invocation(
+    physical_devices: &[PathBuf],
+    candidate: &Candidate,
+) -> Result<CommandInvocation> {
+    change_invocation(physical_devices, candidate, true)
+}
+
+fn deactivation_invocation(
+    physical_devices: &[PathBuf],
+    candidate: &Candidate,
+) -> Result<CommandInvocation> {
+    change_invocation(physical_devices, candidate, false)
+}
+
+fn change_invocation(
+    physical_devices: &[PathBuf],
+    candidate: &Candidate,
+    activate: bool,
+) -> Result<CommandInvocation> {
+    let mut args = vec![
+        OsString::from("lvchange"),
+        OsString::from(if activate { "-ay" } else { "-an" }),
+        OsString::from("--poll"),
+        OsString::from("n"),
+        OsString::from("--sysinit"),
+        OsString::from("--noudevsync"),
+        OsString::from("--nohints"),
+        OsString::from("--nolocking"),
+    ];
+    append_devices(&mut args, physical_devices)?;
+    args.push(OsString::from("--select"));
+    args.push(OsString::from(format!(
+        "vg_uuid={} && vg_tags={} && lv_uuid={} && lv_tags={}",
+        candidate.vg_uuid.display,
+        VG_TAG,
+        candidate.lv_uuid.display,
+        candidate.role.tag()
+    )));
+    Ok(CommandInvocation {
+        program: PathBuf::from(LVM),
+        args,
+    })
+}
+
+fn append_devices(args: &mut Vec<OsString>, physical_devices: &[PathBuf]) -> Result<()> {
+    validate_physical_devices(physical_devices)?;
+    for device in physical_devices {
+        args.push(OsString::from("--devices"));
+        args.push(device.as_os_str().to_owned());
+    }
+    Ok(())
+}
+
+fn validate_physical_devices(physical_devices: &[PathBuf]) -> Result<()> {
+    if physical_devices.is_empty() {
+        return Err("LVM physical-device allowlist must not be empty".to_string());
+    }
+
+    let mut seen = BTreeSet::new();
+    for device in physical_devices {
+        if !device.is_absolute() || !device.starts_with("/dev") || device == Path::new("/dev") {
+            return Err(format!(
+                "LVM physical device must be an absolute path below /dev: {}",
+                device.display()
+            ));
+        }
+        if device
+            .components()
+            .any(|part| !matches!(part, Component::RootDir | Component::Normal(_)))
+        {
+            return Err(format!(
+                "LVM physical device path is not normalized: {}",
+                device.display()
+            ));
+        }
+        let Some(text) = device.to_str() else {
+            return Err("LVM physical device path is not UTF-8".to_string());
+        };
+        if text.contains(',') {
+            return Err(format!(
+                "LVM physical device path contains the --devices separator: {}",
+                device.display()
+            ));
+        }
+        if !seen.insert(device.clone()) {
+            return Err(format!(
+                "duplicate LVM physical device: {}",
+                device.display()
+            ));
+        }
+    }
+    Ok(())
+}
+
+fn run_checked<R: CommandRunner>(runner: &R, invocation: CommandInvocation) -> Result<Vec<u8>> {
+    let output = runner.run(&invocation)?;
+    if !output.success {
+        let stderr = String::from_utf8_lossy(&output.stderr);
+        return Err(format!(
+            "{} {} failed: {}",
+            invocation.program.display(),
+            invocation
+                .args
+                .first()
+                .map(|argument| argument.to_string_lossy())
+                .unwrap_or_default(),
+            stderr.trim()
+        ));
+    }
+    if !output.stderr.is_empty() {
+        tracing::debug!(
+            command = ?invocation.args.first(),
+            stderr = %String::from_utf8_lossy(&output.stderr).trim(),
+            "LVM command emitted diagnostics"
+        );
+    }
+    Ok(output.stdout)
+}
+
+#[derive(Debug, Deserialize)]
+struct LvsOutput {
+    report: Vec<LvsReport>,
+}
+
+#[derive(Debug, Deserialize)]
+struct LvsReport {
+    lv: Vec<RawLogicalVolume>,
+}
+
+#[derive(Debug, Deserialize)]
+struct RawLogicalVolume {
+    vg_name: String,
+    lv_name: String,
+    vg_uuid: String,
+    lv_uuid: String,
+    vg_tags: Vec<String>,
+    lv_tags: Vec<String>,
+    lv_active: u8,
+}
+
+#[derive(Clone, Debug)]
+struct LvmUuid {
+    display: String,
+    compact: String,
+}
+
+impl LvmUuid {
+    fn parse(kind: &str, value: String) -> Result<Self> {
+        const GROUPS: [usize; 7] = [6, 4, 4, 4, 4, 4, 6];
+
+        let groups = value.split('-').collect::<Vec<_>>();
+        if groups.len() != GROUPS.len()
+            || groups
+                .iter()
+                .zip(GROUPS)
+                .any(|(group, length)| group.len() != length || !group.bytes().all(is_lvm_id_byte))
+        {
+            return Err(format!("malformed LVM {kind} UUID: {value}"));
+        }
+        let compact = groups.concat();
+        Ok(Self {
+            display: value,
+            compact,
+        })
+    }
+}
+
+fn is_lvm_id_byte(byte: u8) -> bool {
+    byte.is_ascii_alphanumeric()
+}
+
+#[derive(Clone, Debug)]
+struct Candidate {
+    role: LogicalVolumeRole,
+    vg_name: String,
+    lv_name: String,
+    vg_uuid: LvmUuid,
+    lv_uuid: LvmUuid,
+}
+
+impl Candidate {
+    fn dm_uuid(&self) -> String {
+        format!("LVM-{}{}", self.vg_uuid.compact, self.lv_uuid.compact)
+    }
+}
+
+fn parse_candidates(json: &[u8], expected_vg_uuid: &LvmUuid) -> Result<Vec<Candidate>> {
+    let output: LvsOutput =
+        serde_json::from_slice(json).map_err(|err| format!("parse lvs JSON report: {err}"))?;
+    let mut candidates = Vec::new();
+    let mut lv_uuids = BTreeSet::new();
+    let mut vg_names = BTreeMap::<String, String>::new();
+    let mut vg_uuids = BTreeMap::<String, String>::new();
+    let mut lv_names = BTreeSet::new();
+
+    for raw in output.report.into_iter().flat_map(|report| report.lv) {
+        let vg_tag_count = raw
+            .vg_tags
+            .iter()
+            .filter(|tag| tag.as_str() == VG_TAG)
+            .count();
+        if vg_tag_count == 0 {
+            continue;
+        }
+        if vg_tag_count != 1 {
+            return Err(format!(
+                "LVM volume group {} repeats the PocketBoot VG tag",
+                raw.vg_name
+            ));
+        }
+        let Some(role) = LogicalVolumeRole::from_tags(&raw.lv_tags)? else {
+            // Untagged pool/data/metadata dependencies are intentionally left
+            // to LVM's dependency activation rather than exposed as boot LVs.
+            continue;
+        };
+
+        validate_lvm_name("VG", &raw.vg_name)?;
+        validate_lvm_name("LV", &raw.lv_name)?;
+        let vg_uuid = LvmUuid::parse("VG", raw.vg_uuid)?;
+        let lv_uuid = LvmUuid::parse("LV", raw.lv_uuid)?;
+        if raw.lv_active != 0 {
+            return Err(format!(
+                "PocketBoot LVM candidate is already active: {}/{} ({})",
+                raw.vg_name, raw.lv_name, lv_uuid.display
+            ));
+        }
+
+        if !lv_uuids.insert(lv_uuid.compact.clone()) {
+            return Err(format!("duplicate LVM LV UUID: {}", lv_uuid.display));
+        }
+        match vg_names.entry(raw.vg_name.clone()) {
+            std::collections::btree_map::Entry::Vacant(entry) => {
+                entry.insert(vg_uuid.compact.clone());
+            }
+            std::collections::btree_map::Entry::Occupied(entry)
+                if entry.get() != &vg_uuid.compact =>
+            {
+                return Err(format!(
+                    "LVM VG name {} refers to multiple UUIDs",
+                    raw.vg_name
+                ));
+            }
+            std::collections::btree_map::Entry::Occupied(_) => {}
+        }
+        match vg_uuids.entry(vg_uuid.compact.clone()) {
+            std::collections::btree_map::Entry::Vacant(entry) => {
+                entry.insert(raw.vg_name.clone());
+            }
+            std::collections::btree_map::Entry::Occupied(entry) if entry.get() != &raw.vg_name => {
+                return Err(format!(
+                    "LVM VG UUID {} has multiple names",
+                    vg_uuid.display
+                ));
+            }
+            std::collections::btree_map::Entry::Occupied(_) => {}
+        }
+        if !lv_names.insert((vg_uuid.compact.clone(), raw.lv_name.clone())) {
+            return Err(format!(
+                "duplicate LVM LV name in VG {}: {}",
+                raw.vg_name, raw.lv_name
+            ));
+        }
+
+        candidates.push(Candidate {
+            role,
+            vg_name: raw.vg_name,
+            lv_name: raw.lv_name,
+            vg_uuid,
+            lv_uuid,
+        });
+    }
+
+    if vg_uuids.len() > 1 {
+        return Err(format!(
+            "LVM report contains candidates from multiple PocketBoot VGs: {}",
+            vg_uuids.keys().cloned().collect::<Vec<_>>().join(",")
+        ));
+    }
+    if let Some(actual_vg_uuid) = vg_uuids.keys().next()
+        && actual_vg_uuid != &expected_vg_uuid.compact
+    {
+        return Err(format!(
+            "PocketBoot VG UUID does not match expected {}",
+            expected_vg_uuid.display
+        ));
+    }
+    Ok(candidates)
+}
+
+fn validate_lvm_name(kind: &str, name: &str) -> Result<()> {
+    if name.is_empty()
+        || name.len() > 127
+        || name == "."
+        || name == ".."
+        || name.starts_with('-')
+        || !name
+            .bytes()
+            .all(|byte| byte.is_ascii_alphanumeric() || b"+_.-".contains(&byte))
+    {
+        return Err(format!("invalid LVM {kind} name: {name}"));
+    }
+    Ok(())
+}
+
+fn ensure_not_preexisting(sys_block: &Path, candidates: &[Candidate]) -> Result<()> {
+    if candidates.is_empty() {
+        return Ok(());
+    }
+    let expected = candidates
+        .iter()
+        .map(Candidate::dm_uuid)
+        .collect::<BTreeSet<_>>();
+    for node in dm_nodes(sys_block)? {
+        if expected.contains(&node.uuid) {
+            return Err(format!(
+                "refusing to activate pre-existing LVM mapping {} ({})",
+                node.name, node.uuid
+            ));
+        }
+    }
+    Ok(())
+}
+
+fn map_activated(
+    sys_block: &Path,
+    candidates: Vec<Candidate>,
+) -> Result<Vec<ActivatedLogicalVolume>> {
+    if candidates.is_empty() {
+        return Ok(Vec::new());
+    }
+    let expected = candidates
+        .iter()
+        .map(|candidate| candidate.dm_uuid())
+        .collect::<BTreeSet<_>>();
+    let mut mappings = BTreeMap::<String, String>::new();
+    for node in dm_nodes(sys_block)? {
+        if !node.uuid.starts_with("LVM-") || !expected.contains(&node.uuid) {
+            continue;
+        }
+        let ro = read_trimmed(&node.path.join("ro"))?;
+        if ro != "1" {
+            return Err(format!(
+                "LVM device {} ({}) is not top-level read-only: ro={ro}",
+                node.name, node.uuid
+            ));
+        }
+        if let Some(previous) = mappings.insert(node.uuid.clone(), node.name.clone()) {
+            return Err(format!(
+                "LVM device UUID {} maps to both {previous} and {}",
+                node.uuid, node.name
+            ));
+        }
+    }
+
+    candidates
+        .into_iter()
+        .map(|candidate| {
+            let dm_uuid = candidate.dm_uuid();
+            let name = mappings
+                .remove(&dm_uuid)
+                .ok_or_else(|| format!("activated LVM device not found in sysfs: {dm_uuid}"))?;
+            Ok(ActivatedLogicalVolume {
+                role: candidate.role,
+                vg_name: candidate.vg_name,
+                lv_name: candidate.lv_name,
+                vg_uuid: candidate.vg_uuid.display,
+                lv_uuid: candidate.lv_uuid.display,
+                device: Path::new("/dev").join(name),
+            })
+        })
+        .collect()
+}
+
+struct DmNode {
+    name: String,
+    path: PathBuf,
+    uuid: String,
+}
+
+fn dm_nodes(sys_block: &Path) -> Result<Vec<DmNode>> {
+    let mut entries = fs::read_dir(sys_block)
+        .map_err(|err| format!("read {}: {err}", sys_block.display()))?
+        .collect::<std::io::Result<Vec<_>>>()
+        .map_err(|err| format!("read {} entry: {err}", sys_block.display()))?;
+    entries.sort_by_key(fs::DirEntry::file_name);
+
+    let mut nodes = Vec::new();
+    for entry in entries {
+        let name = entry.file_name();
+        let Some(name) = name.to_str() else {
+            continue;
+        };
+        if !is_dm_block_name(name) {
+            continue;
+        }
+        let path = entry.path();
+        nodes.push(DmNode {
+            name: name.to_string(),
+            uuid: read_trimmed(&path.join("dm/uuid"))?,
+            path,
+        });
+    }
+    Ok(nodes)
+}
+
+fn is_dm_block_name(name: &str) -> bool {
+    let Some(index) = name.strip_prefix("dm-") else {
+        return false;
+    };
+    !index.is_empty() && index.bytes().all(|byte| byte.is_ascii_digit())
+}
+
+fn read_trimmed(path: &Path) -> Result<String> {
+    fs::read_to_string(path)
+        .map(|value| value.trim().to_string())
+        .map_err(|err| format!("read {}: {err}", path.display()))
+}
