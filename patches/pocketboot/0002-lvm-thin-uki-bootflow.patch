diff --git a/src/uki.rs b/src/uki.rs
new file mode 100644
index 0000000000000000000000000000000000000000..87694432da4c1730e5f5461a18ee88d6919e7e36
--- /dev/null
+++ b/src/uki.rs
@@ -0,0 +1,523 @@
+use std::{io, str};
+
+use crate::pe;
+
+const LINUX_SECTION: &[u8] = b".linux";
+const INITRD_SECTION: &[u8] = b".initrd";
+const CMDLINE_SECTION: &[u8] = b".cmdline";
+const OSREL_SECTION: &[u8] = b".osrel";
+const UNAME_SECTION: &[u8] = b".uname";
+const DTB_SECTION: &[u8] = b".dtb";
+const DTBAUTO_SECTION: &[u8] = b".dtbauto";
+const PROFILE_SECTION: &[u8] = b".profile";
+
+#[derive(Debug)]
+pub(crate) struct Uki<'a> {
+    // Resolved profiles borrow their payloads directly from the original PE image.
+    profiles: Vec<Profile<'a>>,
+    #[cfg_attr(not(test), allow(dead_code))]
+    has_explicit_profiles: bool,
+}
+
+impl<'a> Uki<'a> {
+    pub(crate) fn parse(data: &'a [u8]) -> io::Result<Option<Self>> {
+        let Some(image) = pe::Image::parse(data)? else {
+            return Ok(None);
+        };
+        if image.machine() != pe::IMAGE_FILE_MACHINE_ARM64 {
+            return invalid_data(format!(
+                "UKI PE/COFF image is not ARM64: machine=0x{:04x}",
+                image.machine()
+            ));
+        }
+
+        Self::from_pe(&image).map(Some)
+    }
+
+    fn from_pe(image: &pe::Image<'a>) -> io::Result<Self> {
+        let mut base = SectionSet::default();
+        let mut sources = Vec::<ProfileSource<'a>>::new();
+        let mut current_profile = None;
+
+        for section in image.sections() {
+            if section.has_name(PROFILE_SECTION) {
+                let index = sources.len();
+                let metadata = ProfileMetadata::parse(section.data())?;
+                sources.push(ProfileSource {
+                    metadata,
+                    sections: SectionSet::default(),
+                });
+                current_profile = Some(index);
+                continue;
+            }
+
+            let (sections, scope) = match current_profile {
+                Some(index) => (&mut sources[index].sections, format!("profile @{index}")),
+                None => (&mut base, "base profile".to_string()),
+            };
+            sections.insert(section, &scope)?;
+        }
+
+        let has_explicit_profiles = !sources.is_empty();
+        let profiles = if has_explicit_profiles {
+            sources
+                .into_iter()
+                .enumerate()
+                .map(|(index, source)| {
+                    Profile::resolve(index, source.metadata, &base, Some(&source.sections))
+                })
+                .collect::<io::Result<Vec<_>>>()?
+        } else {
+            vec![Profile::resolve(
+                0,
+                ProfileMetadata::default(),
+                &base,
+                None,
+            )?]
+        };
+
+        Ok(Self {
+            profiles,
+            has_explicit_profiles,
+        })
+    }
+
+    pub(crate) fn profiles(&self) -> &[Profile<'a>] {
+        &self.profiles
+    }
+
+    pub(crate) fn profile(&self, index: usize) -> Option<&Profile<'a>> {
+        self.profiles.get(index)
+    }
+
+    #[cfg_attr(not(test), allow(dead_code))]
+    pub(crate) fn has_explicit_profiles(&self) -> bool {
+        self.has_explicit_profiles
+    }
+}
+
+#[derive(Clone, Debug, Default, Eq, PartialEq)]
+pub(crate) struct ProfileMetadata<'a> {
+    raw: Option<&'a str>,
+    id: Option<String>,
+    title: Option<String>,
+}
+
+impl<'a> ProfileMetadata<'a> {
+    fn parse(data: &'a [u8]) -> io::Result<Self> {
+        let raw = section_text(data, ".profile")?;
+        Ok(Self {
+            raw: Some(raw),
+            id: assignment_value(raw, "ID")?,
+            title: assignment_value(raw, "TITLE")?,
+        })
+    }
+
+    #[cfg_attr(not(test), allow(dead_code))]
+    pub(crate) fn raw(&self) -> Option<&'a str> {
+        self.raw
+    }
+
+    #[cfg_attr(not(test), allow(dead_code))]
+    pub(crate) fn id(&self) -> Option<&str> {
+        self.id.as_deref()
+    }
+
+    pub(crate) fn title(&self) -> Option<&str> {
+        self.title.as_deref()
+    }
+}
+
+#[derive(Debug)]
+pub(crate) struct Profile<'a> {
+    index: usize,
+    metadata: ProfileMetadata<'a>,
+    linux: &'a [u8],
+    initrd: Option<&'a [u8]>,
+    cmdline: Option<&'a str>,
+    osrel: Option<&'a str>,
+    uname: Option<&'a str>,
+    dtb: Option<&'a [u8]>,
+    dtbauto: Vec<&'a [u8]>,
+}
+
+impl<'a> Profile<'a> {
+    fn resolve(
+        index: usize,
+        metadata: ProfileMetadata<'a>,
+        base: &SectionSet<'a>,
+        overrides: Option<&SectionSet<'a>>,
+    ) -> io::Result<Self> {
+        let linux = overrides
+            .and_then(|sections| sections.linux)
+            .or(base.linux)
+            .ok_or_else(|| invalid_data_error(format!("profile @{index} has no .linux section")))?;
+        if linux.is_empty() {
+            return invalid_data(format!("profile @{index} has an empty .linux section"));
+        }
+
+        let initrd = overrides
+            .and_then(|sections| sections.initrd)
+            .or(base.initrd);
+        let cmdline = overrides
+            .and_then(|sections| sections.cmdline)
+            .or(base.cmdline);
+        let osrel = overrides.and_then(|sections| sections.osrel).or(base.osrel);
+        let uname = overrides.and_then(|sections| sections.uname).or(base.uname);
+        let dtb = overrides.and_then(|sections| sections.dtb).or(base.dtb);
+        // Repeated .dtbauto sections form one ordered value: any profile-local
+        // occurrence replaces the complete base list, like other section types.
+        let dtbauto = match overrides {
+            Some(sections) if !sections.dtbauto.is_empty() => sections.dtbauto.clone(),
+            _ => base.dtbauto.clone(),
+        };
+
+        Ok(Self {
+            index,
+            metadata,
+            linux,
+            initrd,
+            cmdline,
+            osrel,
+            uname,
+            dtb,
+            dtbauto,
+        })
+    }
+
+    pub(crate) fn index(&self) -> usize {
+        self.index
+    }
+
+    pub(crate) fn metadata(&self) -> &ProfileMetadata<'a> {
+        &self.metadata
+    }
+
+    pub(crate) fn linux(&self) -> &'a [u8] {
+        self.linux
+    }
+
+    pub(crate) fn initrd(&self) -> Option<&'a [u8]> {
+        self.initrd
+    }
+
+    pub(crate) fn cmdline(&self) -> Option<&'a str> {
+        self.cmdline
+    }
+
+    #[cfg_attr(not(test), allow(dead_code))]
+    pub(crate) fn osrel(&self) -> Option<&'a str> {
+        self.osrel
+    }
+
+    pub(crate) fn osrel_value(&self, key: &str) -> io::Result<Option<String>> {
+        match self.osrel {
+            Some(osrel) => assignment_value(osrel, key),
+            None => Ok(None),
+        }
+    }
+
+    pub(crate) fn uname(&self) -> Option<&'a str> {
+        self.uname
+    }
+
+    pub(crate) fn dtb(&self) -> Option<&'a [u8]> {
+        self.dtb
+    }
+
+    pub(crate) fn dtbauto(&self) -> &[&'a [u8]] {
+        &self.dtbauto
+    }
+}
+
+#[derive(Clone, Debug, Default)]
+struct SectionSet<'a> {
+    linux: Option<&'a [u8]>,
+    initrd: Option<&'a [u8]>,
+    cmdline: Option<&'a str>,
+    osrel: Option<&'a str>,
+    uname: Option<&'a str>,
+    dtb: Option<&'a [u8]>,
+    dtbauto: Vec<&'a [u8]>,
+}
+
+impl<'a> SectionSet<'a> {
+    fn insert(&mut self, section: &pe::Section<'a>, scope: &str) -> io::Result<()> {
+        if section.has_name(LINUX_SECTION) {
+            set_once(&mut self.linux, section.data(), ".linux", scope)
+        } else if section.has_name(INITRD_SECTION) {
+            set_once(&mut self.initrd, section.data(), ".initrd", scope)
+        } else if section.has_name(CMDLINE_SECTION) {
+            let value = section_text(section.data(), ".cmdline")?;
+            set_once(&mut self.cmdline, value, ".cmdline", scope)
+        } else if section.has_name(OSREL_SECTION) {
+            let value = section_text(section.data(), ".osrel")?;
+            set_once(&mut self.osrel, value, ".osrel", scope)
+        } else if section.has_name(UNAME_SECTION) {
+            let value = section_text(section.data(), ".uname")?;
+            set_once(&mut self.uname, value, ".uname", scope)
+        } else if section.has_name(DTB_SECTION) {
+            set_once(&mut self.dtb, section.data(), ".dtb", scope)
+        } else if section.has_name(DTBAUTO_SECTION) {
+            self.dtbauto.push(section.data());
+            Ok(())
+        } else {
+            Ok(())
+        }
+    }
+}
+
+#[derive(Debug)]
+struct ProfileSource<'a> {
+    metadata: ProfileMetadata<'a>,
+    sections: SectionSet<'a>,
+}
+
+fn set_once<T>(slot: &mut Option<T>, value: T, section: &str, scope: &str) -> io::Result<()> {
+    if slot.is_some() {
+        return invalid_data(format!("duplicate {section} section in {scope}"));
+    }
+    *slot = Some(value);
+    Ok(())
+}
+
+fn section_text<'a>(data: &'a [u8], section: &str) -> io::Result<&'a str> {
+    let end = data
+        .iter()
+        .rposition(|byte| *byte != 0)
+        .map_or(0, |index| index + 1);
+    let data = &data[..end];
+    if data.contains(&0) {
+        return invalid_data(format!("{section} section contains an interior NUL byte"));
+    }
+    str::from_utf8(data)
+        .map_err(|err| invalid_data_error(format!("{section} section is not valid UTF-8: {err}")))
+}
+
+fn assignment_value(text: &str, key: &str) -> io::Result<Option<String>> {
+    for line in text.lines() {
+        let line = line.trim();
+        if line.is_empty() || line.starts_with('#') {
+            continue;
+        }
+        let Some((name, value)) = line.split_once('=') else {
+            continue;
+        };
+        if name.trim() == key {
+            return decode_assignment_value(value.trim()).map(Some);
+        }
+    }
+    Ok(None)
+}
+
+fn decode_assignment_value(value: &str) -> io::Result<String> {
+    let Some(first) = value.chars().next() else {
+        return Ok(String::new());
+    };
+    match first {
+        '\'' | '"' => {
+            if value.len() < 2 || !value.ends_with(first) {
+                return invalid_data("unterminated quoted UKI metadata value");
+            }
+            let inner = &value[first.len_utf8()..value.len() - first.len_utf8()];
+            if first == '\'' {
+                Ok(inner.to_string())
+            } else {
+                unescape_assignment_value(inner)
+            }
+        }
+        _ => unescape_assignment_value(value),
+    }
+}
+
+fn unescape_assignment_value(value: &str) -> io::Result<String> {
+    let mut result = String::with_capacity(value.len());
+    let mut chars = value.chars();
+    while let Some(character) = chars.next() {
+        if character == '\\' {
+            let Some(escaped) = chars.next() else {
+                return invalid_data("UKI metadata value ends with a backslash");
+            };
+            result.push(escaped);
+        } else {
+            result.push(character);
+        }
+    }
+    Ok(result)
+}
+
+fn invalid_data<T>(message: impl Into<String>) -> io::Result<T> {
+    Err(invalid_data_error(message))
+}
+
+fn invalid_data_error(message: impl Into<String>) -> io::Error {
+    io::Error::new(io::ErrorKind::InvalidData, message.into())
+}
