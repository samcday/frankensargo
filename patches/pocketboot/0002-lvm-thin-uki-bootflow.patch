+fn stamp_input(target: &str) -> StampInput {
+    StampInput {
+        recipe_version: RECIPE_VERSION,
+        target: target.to_string(),
+        alpine_arch: ALPINE_ARCH.to_string(),
+        alpine_release: ALPINE_RELEASE.to_string(),
+        alpine_aports_commit: ALPINE_APORTS_COMMIT.to_string(),
+        package: PACKAGE.to_string(),
+        package_url: PACKAGE_URL.to_string(),
+        package_sha256: PACKAGE_SHA256.to_string(),
+        package_member: PACKAGE_MEMBER.to_string(),
+        binary_sha256: BINARY_SHA256.to_string(),
+    }
+}
+
+fn cache_hit(paths: &Lvm2Paths, input: &StampInput) -> Result<bool> {
+    let contents = match fs::read_to_string(&paths.stamp) {
+        Ok(contents) => contents,
+        Err(err) if err.kind() == std::io::ErrorKind::NotFound => return Ok(false),
+        Err(err) => return Err(format!("read {}: {err}", paths.stamp.display())),
+    };
+    let Ok(stamp) = toml::from_str::<Lvm2Stamp>(&contents) else {
+        return Ok(false);
+    };
+    if stamp.input != *input || !paths.binary.is_file() {
+        return Ok(false);
+    }
+
+    let Ok(output) = output_stamp(&paths.binary) else {
+        return Ok(false);
+    };
+    Ok(stamp.output == output)
+}
+
+fn ensure_archive(path: &Path) -> Result<()> {
+    if path.is_file() {
+        return verify_hash(path, PACKAGE_SHA256, "LVM2 APK");
+    }
+
+    if let Some(parent) = path
+        .parent()
+        .filter(|parent| !parent.as_os_str().is_empty())
+    {
+        fs::create_dir_all(parent).map_err(|err| format!("create {}: {err}", parent.display()))?;
+    }
+
+    let tmp = path.with_extension("apk.tmp");
+    remove_stale_temp(&tmp)?;
+    let curl = env::var_os("CURL").unwrap_or_else(|| "curl".into());
+    let mut command = Command::new(curl);
+    command
+        .args(["--fail", "--location", "--output"])
+        .arg(&tmp)
+        .arg(PACKAGE_URL);
+    run_command(command, "download static LVM2 APK")?;
+    verify_hash(&tmp, PACKAGE_SHA256, "LVM2 APK")?;
+    fs::rename(&tmp, path)
+        .map_err(|err| format!("rename {} to {}: {err}", tmp.display(), path.display()))
+}
+
+fn extract_binary(archive: &Path, binary: &Path) -> Result<()> {
+    ensure_file(archive, "static LVM2 APK")?;
+    let parent = binary
+        .parent()
+        .ok_or_else(|| format!("LVM2 binary path has no parent: {}", binary.display()))?;
+    fs::create_dir_all(parent).map_err(|err| format!("create {}: {err}", parent.display()))?;
+
+    let tmp = binary.with_extension("static.tmp");
+    remove_stale_temp(&tmp)?;
+    let output = File::create(&tmp).map_err(|err| format!("create {}: {err}", tmp.display()))?;
+    let bsdtar = env::var_os("BSDTAR").unwrap_or_else(|| "bsdtar".into());
+    let mut command = Command::new(bsdtar);
+    command
+        .arg("-xOf")
+        .arg(archive)
+        .arg(PACKAGE_MEMBER)
+        .stdout(Stdio::from(output));
+    run_command(command, "extract static LVM2 from APK")?;
+
+    verify_lvm_static(&tmp)?;
+    fs::set_permissions(&tmp, fs::Permissions::from_mode(0o755))
+        .map_err(|err| format!("chmod {}: {err}", tmp.display()))?;
+    fs::rename(&tmp, binary)
+        .map_err(|err| format!("rename {} to {}: {err}", tmp.display(), binary.display()))
+}
+
+fn remove_stale_temp(path: &Path) -> Result<()> {
+    match fs::remove_file(path) {
+        Ok(()) => Ok(()),
+        Err(err) if err.kind() == std::io::ErrorKind::NotFound => Ok(()),
+        Err(err) => Err(format!("remove stale {}: {err}", path.display())),
+    }
+}
+
+fn write_stamp(path: &Path, stamp: &Lvm2Stamp) -> Result<()> {
+    let contents =
+        toml::to_string_pretty(stamp).map_err(|err| format!("encode LVM2 stamp: {err}"))?;
+    fs::write(path, contents).map_err(|err| format!("write {}: {err}", path.display()))
+}
+
+fn output_stamp(binary: &Path) -> Result<StampOutput> {
+    verify_lvm_static(binary)?;
+    Ok(StampOutput {
+        binary_sha256: hash_file(binary)?,
+        binary_len: fs::metadata(binary)
+            .map_err(|err| format!("stat {}: {err}", binary.display()))?
+            .len(),
+    })
+}
+
+fn verify_lvm_static(path: &Path) -> Result<()> {
+    verify_hash(path, BINARY_SHA256, "static LVM2 binary")?;
+    let bytes = fs::read(path).map_err(|err| format!("read {}: {err}", path.display()))?;
+    verify_static_aarch64_elf(&bytes)
+        .map_err(|err| format!("verify static LVM2 ELF {}: {err}", path.display()))
+}
+
+fn verify_hash(path: &Path, expected: &str, description: &str) -> Result<()> {
+    let actual = hash_file(path)?;
+    if actual == expected {
+        Ok(())
+    } else {
+        Err(format!(
+            "{description} checksum mismatch for {}: expected {expected}, got {actual}",
+            path.display()
+        ))
+    }
+}
+
+fn hash_file(path: &Path) -> Result<String> {
+    let mut file = File::open(path).map_err(|err| format!("open {}: {err}", path.display()))?;
+    let mut hasher = Sha256::new();
+    let mut buffer = [0; 64 * 1024];
+    loop {
+        let read = file
+            .read(&mut buffer)
+            .map_err(|err| format!("read {}: {err}", path.display()))?;
+        if read == 0 {
+            break;
+        }
+        hasher.update(&buffer[..read]);
+    }
+    Ok(format!("{:x}", hasher.finalize()))
+}
+
+fn verify_static_aarch64_elf(bytes: &[u8]) -> Result<()> {
+    if bytes.len() < ELF64_HEADER_SIZE || bytes.get(..4) != Some(b"\x7fELF") {
+        return Err("not an ELF file".to_string());
+    }
+    if bytes[4] != ELFCLASS64 || bytes[5] != ELFDATA2LSB || bytes[6] != 1 {
+        return Err("expected a little-endian ELF64 version 1 image".to_string());
+    }
+
+    let elf_type = read_u16(bytes, 16, "ELF type")?;
+    if !matches!(elf_type, ET_EXEC | ET_DYN) {
+        return Err(format!("unsupported ELF type {elf_type}"));
+    }
+    let machine = read_u16(bytes, 18, "ELF machine")?;
+    if machine != EM_AARCH64 {
+        return Err(format!(
+            "ELF is not AArch64: machine={machine}, expected {EM_AARCH64}"
+        ));
+    }
+
+    let phoff = usize_from_u64(read_u64(bytes, 32, "program header offset")?)?;
+    let phentsize = usize::from(read_u16(bytes, 54, "program header entry size")?);
+    let phnum = usize::from(read_u16(bytes, 56, "program header count")?);
+    if phentsize < ELF64_PROGRAM_HEADER_SIZE || phnum == 0 {
+        return Err("ELF has no usable program header table".to_string());
+    }
+    let table_size = phentsize
+        .checked_mul(phnum)
+        .ok_or_else(|| "program header table size overflows".to_string())?;
+    let table_end = phoff
+        .checked_add(table_size)
+        .ok_or_else(|| "program header table end overflows".to_string())?;
+    if table_end > bytes.len() {
+        return Err("program header table exceeds ELF file".to_string());
+    }
+
+    let mut has_load = false;
+    for index in 0..phnum {
+        let start = phoff + index * phentsize;
+        let header = &bytes[start..start + phentsize];
+        let program_type = read_u32(header, 0, "program header type")?;
+        match program_type {
+            PT_LOAD => has_load = true,
+            PT_INTERP => return Err("ELF contains a PT_INTERP dynamic loader".to_string()),
+            PT_DYNAMIC => verify_dynamic_segment(bytes, header)?,
+            _ => {}
+        }
+    }
+    if !has_load {
+        return Err("ELF contains no loadable segment".to_string());
+    }
+    Ok(())
+}
+
+fn verify_dynamic_segment(elf: &[u8], header: &[u8]) -> Result<()> {
+    let offset = usize_from_u64(read_u64(header, 8, "dynamic segment offset")?)?;
+    let size = usize_from_u64(read_u64(header, 32, "dynamic segment size")?)?;
+    if size == 0 || size % ELF64_DYNAMIC_ENTRY_SIZE != 0 {
+        return Err("ELF has a malformed dynamic segment".to_string());
+    }
+    let end = offset
+        .checked_add(size)
+        .ok_or_else(|| "dynamic segment end overflows".to_string())?;
+    let entries = elf
+        .get(offset..end)
+        .ok_or_else(|| "dynamic segment exceeds ELF file".to_string())?;
+
+    let mut terminated = false;
+    for entry in entries.chunks_exact(ELF64_DYNAMIC_ENTRY_SIZE) {
+        match read_u64(entry, 0, "dynamic tag")? {
+            DT_NULL => {
+                terminated = true;
+                break;
+            }
+            DT_NEEDED => {
+                return Err("ELF contains a DT_NEEDED shared-library dependency".to_string());
+            }
+            _ => {}
+        }
+    }
+    if !terminated {
+        return Err("ELF dynamic segment is not terminated".to_string());
+    }
+    Ok(())
+}
+
+fn usize_from_u64(value: u64) -> Result<usize> {
+    usize::try_from(value).map_err(|_| format!("value does not fit usize: {value}"))
+}
+
+fn read_u16(bytes: &[u8], offset: usize, description: &str) -> Result<u16> {
+    let value = bytes
+        .get(offset..offset + 2)
+        .ok_or_else(|| format!("{description} is truncated"))?;
+    Ok(u16::from_le_bytes(value.try_into().unwrap()))
+}
+
+fn read_u32(bytes: &[u8], offset: usize, description: &str) -> Result<u32> {
+    let value = bytes
+        .get(offset..offset + 4)
+        .ok_or_else(|| format!("{description} is truncated"))?;
+    Ok(u32::from_le_bytes(value.try_into().unwrap()))
+}
+
+fn read_u64(bytes: &[u8], offset: usize, description: &str) -> Result<u64> {
+    let value = bytes
+        .get(offset..offset + 8)
+        .ok_or_else(|| format!("{description} is truncated"))?;
+    Ok(u64::from_le_bytes(value.try_into().unwrap()))
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    #[test]
+    fn accepts_static_aarch64_pie() {
+        let elf = test_elf(&[PT_LOAD, PT_DYNAMIC], &[DT_NULL]);
+        verify_static_aarch64_elf(&elf).unwrap();
+    }
+
+    #[test]
+    fn rejects_dynamic_loader() {
+        let elf = test_elf(&[PT_LOAD, PT_INTERP], &[]);
+        let err = verify_static_aarch64_elf(&elf).unwrap_err();
+        assert!(err.contains("PT_INTERP"));
+    }
+
+    #[test]
+    fn rejects_shared_library_dependencies() {
+        let elf = test_elf(&[PT_LOAD, PT_DYNAMIC], &[DT_NEEDED, DT_NULL]);
+        let err = verify_static_aarch64_elf(&elf).unwrap_err();
+        assert!(err.contains("DT_NEEDED"));
+    }
+
+    #[test]
+    fn rejects_wrong_architecture() {
+        let mut elf = test_elf(&[PT_LOAD], &[]);
+        elf[18..20].copy_from_slice(&62u16.to_le_bytes());
+        let err = verify_static_aarch64_elf(&elf).unwrap_err();
+        assert!(err.contains("not AArch64"));
+    }
+
+    #[test]
+    fn rejects_out_of_bounds_program_headers() {
+        let mut elf = test_elf(&[PT_LOAD], &[]);
+        elf[32..40].copy_from_slice(&u64::MAX.to_le_bytes());
+        let err = verify_static_aarch64_elf(&elf).unwrap_err();
+        assert!(err.contains("program header table"));
+    }
+
+    #[test]
+    fn records_reproducible_package_provenance() {
+        let input = stamp_input(TARGET);
+        assert_eq!(input.alpine_release, "v3.23");
+        assert_eq!(input.alpine_arch, "aarch64");
+        assert_eq!(input.alpine_aports_commit, ALPINE_APORTS_COMMIT);
+        assert_eq!(input.package_sha256.len(), 64);
+        assert_eq!(input.binary_sha256.len(), 64);
+        assert!(
+            input
+                .package_url
+                .starts_with("https://dl-cdn.alpinelinux.org/")
+        );
+        assert_eq!(INITRAMFS_BINARY_PATH, "sbin/lvm.static");
+        assert_eq!(
+            Path::new(INITRAMFS_BINARY_PATH)
+                .file_name()
+                .and_then(|name| name.to_str()),
+            Some("lvm.static")
+        );
+    }
+
+    fn test_elf(program_types: &[u32], dynamic_tags: &[u64]) -> Vec<u8> {
+        let phoff = ELF64_HEADER_SIZE;
+        let dynamic_offset = phoff + program_types.len() * ELF64_PROGRAM_HEADER_SIZE;
+        let dynamic_size = dynamic_tags.len() * ELF64_DYNAMIC_ENTRY_SIZE;
+        let mut elf = vec![0; dynamic_offset + dynamic_size];
+        elf[..4].copy_from_slice(b"\x7fELF");
+        elf[4] = ELFCLASS64;
+        elf[5] = ELFDATA2LSB;
+        elf[6] = 1;
+        elf[16..18].copy_from_slice(&ET_DYN.to_le_bytes());
+        elf[18..20].copy_from_slice(&EM_AARCH64.to_le_bytes());
+        elf[20..24].copy_from_slice(&1u32.to_le_bytes());
+        elf[32..40].copy_from_slice(&(phoff as u64).to_le_bytes());
+        elf[52..54].copy_from_slice(&(ELF64_HEADER_SIZE as u16).to_le_bytes());
+        elf[54..56].copy_from_slice(&(ELF64_PROGRAM_HEADER_SIZE as u16).to_le_bytes());
+        elf[56..58].copy_from_slice(&(program_types.len() as u16).to_le_bytes());
+
+        for (index, program_type) in program_types.iter().enumerate() {
+            let start = phoff + index * ELF64_PROGRAM_HEADER_SIZE;
+            elf[start..start + 4].copy_from_slice(&program_type.to_le_bytes());
+            if *program_type == PT_DYNAMIC {
+                elf[start + 8..start + 16].copy_from_slice(&(dynamic_offset as u64).to_le_bytes());
+                elf[start + 32..start + 40].copy_from_slice(&(dynamic_size as u64).to_le_bytes());
+            }
+        }
+        for (index, tag) in dynamic_tags.iter().enumerate() {
+            let start = dynamic_offset + index * ELF64_DYNAMIC_ENTRY_SIZE;
+            elf[start..start + 8].copy_from_slice(&tag.to_le_bytes());
+        }
+        elf
+    }
+}
