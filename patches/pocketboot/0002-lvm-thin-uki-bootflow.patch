+    fn test_gpt_disk_image() -> Vec<u8> {
+        const BLOCK: usize = 512;
+        let mut image = vec![0u8; 128 * BLOCK];
+
+        let mbr_entry = MBR_PARTITION_TABLE_OFFSET;
+        image[mbr_entry + 4] = GPT_PROTECTIVE_MBR_TYPE;
+        image[mbr_entry + 8..mbr_entry + 12].copy_from_slice(&1u32.to_le_bytes());
+        image[mbr_entry + 12..mbr_entry + 16].copy_from_slice(&127u32.to_le_bytes());
+        image[510..512].copy_from_slice(&MBR_SIGNATURE);
+
+        let table_start = 2 * BLOCK;
+        image[table_start..table_start + 16].copy_from_slice(&XBOOTLDR_GUID.0);
+        image[table_start + 32..table_start + 40].copy_from_slice(&40u64.to_le_bytes());
+        image[table_start + 40..table_start + 48].copy_from_slice(&47u64.to_le_bytes());
+        let second = table_start + GPT_MIN_ENTRY_SIZE;
+        image[second..second + 16].copy_from_slice(&ESP_GUID.0);
+        image[second + 32..second + 40].copy_from_slice(&48u64.to_le_bytes());
+        image[second + 40..second + 48].copy_from_slice(&63u64.to_le_bytes());
+        let table_crc = crc32_ieee(&image[table_start..table_start + BLOCK]);
+
+        let header = BLOCK;
+        image[header..header + 8].copy_from_slice(GPT_SIGNATURE);
+        image[header + 8..header + 12].copy_from_slice(&0x0001_0000u32.to_le_bytes());
+        image[header + 12..header + 16]
