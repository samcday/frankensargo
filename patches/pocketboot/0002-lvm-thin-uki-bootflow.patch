+#[cfg(feature = "lvm")]
+fn lvm_disk_candidate(volume: &ActivatedLogicalVolume) -> io::Result<DiskCandidate> {
+    let dm_name = volume
+        .device
+        .file_name()
+        .and_then(|name| name.to_str())
+        .ok_or_else(|| invalid_data("LVM device path has no UTF-8 device name"))?;
+    let Some(index) = dm_name.strip_prefix("dm-") else {
+        return Err(invalid_data(format!(
+            "LVM device is not a dm block node: {}",
+            volume.device.display()
+        )));
+    };
+    if index.is_empty() || !index.bytes().all(|byte| byte.is_ascii_digit()) {
+        return Err(invalid_data(format!(
+            "LVM device has an invalid dm name: {dm_name}"
+        )));
+    }
+
+    let sysfs_path = Path::new(SYS_BLOCK).join(dm_name);
+    if read_trimmed(sysfs_path.join("ro")).as_deref() != Some("1") {
+        return Err(invalid_data(format!(
+            "LVM disk is no longer read-only: {}",
+            volume.device.display()
+        )));
+    }
+    let sectors_512 = read_trimmed(sysfs_path.join("size"))
+        .and_then(|value| value.parse::<u64>().ok())
+        .filter(|size| *size > 0)
+        .ok_or_else(|| invalid_data(format!("LVM disk {dm_name} has no usable size")))?;
+    let logical_block_size = read_trimmed(sysfs_path.join("queue/logical_block_size"))
+        .and_then(|value| value.parse::<u64>().ok())
+        .filter(|value| *value >= 512 && value.is_power_of_two())
+        .unwrap_or(DEFAULT_LOGICAL_BLOCK_SIZE);
+
+    Ok(DiskCandidate {
