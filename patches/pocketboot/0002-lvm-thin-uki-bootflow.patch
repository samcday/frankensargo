+#[cfg(feature = "lvm")]
+fn lvm_boot_partitions(volumes: Vec<ActivatedLogicalVolume>) -> Vec<BootPartitionCandidate> {
+    let mut partitions = Vec::new();
+    for volume in volumes {
+        match volume.role {
+            LogicalVolumeRole::Meta => {}
+            LogicalVolumeRole::BootFs => partitions.push(BootPartitionCandidate {
+                disk: format!("lvm-vg-{}", volume.vg_uuid),
+                partition: format!("lvm-lv-{}", volume.lv_uuid),
+                partno: 0,
+                role: BootPartitionRole::Xbootldr,
+                dev_path: volume.device,
+                removable: false,
+                _loop_device: None,
+            }),
+            LogicalVolumeRole::Disk => {
+                let disk = match lvm_disk_candidate(&volume) {
+                    Ok(disk) => disk,
+                    Err(err) => {
+                        tracing::warn!(
+                            lv_uuid = %volume.lv_uuid,
+                            path = %volume.device.display(),
+                            error = ?err,
+                            "cannot inspect activated LVM disk LV"
+                        );
+                        continue;
+                    }
+                };
+                match sliced_gpt_boot_partitions(&disk) {
+                    Ok(mut candidates) => partitions.append(&mut candidates),
+                    Err(err) => tracing::warn!(
+                        lv_uuid = %volume.lv_uuid,
+                        path = %volume.device.display(),
+                        error = ?err,
+                        "LVM disk LV has no safe GPT boot slices"
+                    ),
+                }
+            }
+        }
+    }
+    partitions
+}
