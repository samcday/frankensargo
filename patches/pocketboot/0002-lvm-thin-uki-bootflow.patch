+#[derive(Debug, Eq, PartialEq)]
+struct ResolvedUkiPayload {
+    linux: Vec<u8>,
+    initrd: Option<Vec<u8>>,
+    cmdline: String,
+    dtb: Option<Vec<u8>>,
+}
+
+fn load_uki(
+    root: &Path,
+    path: &Path,
+    profile: usize,
+    cmdline_override: Option<&str>,
+) -> io::Result<()> {
+    let live_dtb = fs::read(CURRENT_FDT_PATH).map_err(|err| {
+        io::Error::new(
+            err.kind(),
+            format!("read live DTB {CURRENT_FDT_PATH}: {err}"),
+        )
+    })?;
+    let resolved = resolve_uki_file(root, path, profile, cmdline_override, Some(&live_dtb))?;
+    let kernel = kexec::payload_from_bytes("uki-kernel", &resolved.linux)?;
+    let kernel = kexec::prepare_kernel_payload(kernel)?;
+    let initrd = resolved
+        .initrd
+        .as_deref()
+        .map(|data| kexec::payload_from_bytes("uki-initrd", data))
+        .transpose()?;
+    let dtb = resolved
+        .dtb
+        .as_deref()
+        .map(|data| kexec::payload_from_bytes("uki-dtb", data))
+        .transpose()?;
+    KexecImage::new(kernel, initrd, dtb, &resolved.cmdline)?.load()
+}
+
+fn resolve_uki_file(
+    root: &Path,
+    path: &Path,
+    profile: usize,
+    cmdline_override: Option<&str>,
+    live_dtb: Option<&[u8]>,
+) -> io::Result<ResolvedUkiPayload> {
+    let data = read_uki_file_bounded(root, path)?;
+    resolve_uki_bytes(&data, profile, cmdline_override, live_dtb)
+        .map_err(|err| io::Error::new(err.kind(), format!("parse UKI {}: {err}", path.display())))
+}
+
+fn resolve_uki_bytes(
+    data: &[u8],
+    profile_index: usize,
+    cmdline_override: Option<&str>,
+    live_dtb: Option<&[u8]>,
+) -> io::Result<ResolvedUkiPayload> {
+    let uki = uki::Uki::parse(data)?.ok_or_else(|| invalid_data("UKI payload is not PE/COFF"))?;
+    let profile = uki.profile(profile_index).ok_or_else(|| {
+        invalid_data(format!(
+            "UKI profile @{profile_index} is out of range ({} profiles)",
+            uki.profiles().len()
+        ))
+    })?;
+    let dtb = select_uki_dtb(profile, live_dtb).map(<[u8]>::to_vec);
+    // Type #1 BLS options are an explicit policy override. An absent or empty
+    // override keeps the command line embedded in the selected UKI profile.
+    let cmdline = cmdline_override
+        .map(str::trim)
+        .filter(|value| !value.is_empty())
+        .or(profile.cmdline())
+        .unwrap_or_default()
+        .to_string();
+
+    Ok(ResolvedUkiPayload {
+        linux: profile.linux().to_vec(),
+        initrd: profile.initrd().map(<[u8]>::to_vec),
+        cmdline,
+        dtb,
+    })
+}
+
+fn select_uki_dtb<'a>(profile: &uki::Profile<'a>, live_dtb: Option<&[u8]>) -> Option<&'a [u8]> {
+    let live_compatibles = live_dtb.and_then(|dtb| match kexec::fdt_root_compatible_strings(dtb) {
+        Ok(compatibles) => Some(compatibles),
+        Err(err) => {
+            tracing::warn!(error = ?err, "cannot match UKI .dtbauto against malformed live DTB");
+            None
+        }
+    });
+
+    if let Some(live_compatibles) = live_compatibles {
+        for (index, candidate) in profile.dtbauto().iter().copied().enumerate() {
+            let compatibles = match kexec::fdt_root_compatible_strings(candidate) {
+                Ok(compatibles) => compatibles,
+                Err(err) => {
+                    tracing::warn!(index, error = ?err, "ignoring malformed UKI .dtbauto candidate");
+                    continue;
+                }
+            };
+            let Some(first) = compatibles.first() else {
+                tracing::warn!(
+                    index,
+                    "ignoring UKI .dtbauto candidate without a root compatible"
+                );
+                continue;
+            };
+            if live_compatibles.iter().any(|live| live == first) {
+                tracing::info!(index, compatible = first, "selected matching UKI .dtbauto");
+                return Some(candidate);
+            }
+        }
+    }
+
+    profile.dtb()
+}
