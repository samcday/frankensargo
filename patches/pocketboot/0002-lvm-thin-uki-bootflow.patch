+fn decode_arm64_image_payload(payload: &[u8], description: &str) -> Result<Vec<u8>> {
+    if payload.get(ARM64_IMAGE_MAGIC_OFFSET..ARM64_IMAGE_MAGIC_OFFSET + ARM64_IMAGE_MAGIC.len())
+        == Some(ARM64_IMAGE_MAGIC)
+    {
+        return Ok(payload.to_vec());
+    }
+    if payload.get(..GZIP_MAGIC.len()) != Some(GZIP_MAGIC) {
+        return Err(format!(
+            "{description} is neither a raw nor gzip-compressed arm64 Image"
+        ));
+    }
+
+    let mut decoder = MultiGzDecoder::new(payload);
+    let mut image = Vec::new();
+    decoder
+        .by_ref()
+        .take(MAX_DECOMPRESSED_ARM64_IMAGE_BYTES + 1)
+        .read_to_end(&mut image)
+        .map_err(|err| format!("decompress kernel payload {description}: {err}"))?;
+    if image.len() as u64 > MAX_DECOMPRESSED_ARM64_IMAGE_BYTES {
+        return Err(format!(
+            "decompressed kernel payload exceeds {} bytes: {description}",
+            MAX_DECOMPRESSED_ARM64_IMAGE_BYTES
+        ));
+    }
+    if image.get(ARM64_IMAGE_MAGIC_OFFSET..ARM64_IMAGE_MAGIC_OFFSET + ARM64_IMAGE_MAGIC.len())
+        != Some(ARM64_IMAGE_MAGIC)
+    {
+        return Err(format!(
+            "gzip payload did not decompress to an arm64 Image: {description}"
+        ));
+    }
+    Ok(image)
+}
