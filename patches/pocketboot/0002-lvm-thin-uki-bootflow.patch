+
+pub(super) fn build(target_dir: &Path, target: &str) -> Result<Lvm2Install> {
+    if target != TARGET {
+        return Err(format!(
+            "static LVM2 is not pinned for target {target}; supported target: {TARGET}"
+        ));
+    }
+
+    let paths = Lvm2Paths::new(target_dir, target);
+    let input = stamp_input(target);
+    if cache_hit(&paths, &input)? {
+        return Ok(Lvm2Install {
+            binary: paths.binary,
+        });
+    }
+
+    ensure_archive(&paths.archive)?;
+    extract_binary(&paths.archive, &paths.binary)?;
+    let output = output_stamp(&paths.binary)?;
+    write_stamp(&paths.stamp, &Lvm2Stamp { input, output })?;
+
+    Ok(Lvm2Install {
+        binary: paths.binary,
+    })
