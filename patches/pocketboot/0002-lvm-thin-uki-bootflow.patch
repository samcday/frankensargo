+
+pub(crate) fn run(args: Lvm2Args) -> Result<()> {
+    let workspace_root = workspace_root()?;
+    let install = build(&target_dir(&workspace_root), &args.target)?;
+    println!("lvm {}", install.binary.display());
+    println!("source {PACKAGE_URL}");
+    println!("source-sha256 {PACKAGE_SHA256}");
+    println!("aports-commit {ALPINE_APORTS_COMMIT}");
