+fn scan_direct_uki_entries(
+    partition: &BootPartitionCandidate,
+    mount: &MountedPartition,
+) -> Vec<BootEntry> {
+    let directory = mount.root.join(DIRECT_UKI_DIR);
+    if let Err(err) = verify_beneath_without_symlinks(&mount.root, &directory) {
+        if err.kind() == io::ErrorKind::NotFound {
+            tracing::debug!(path = %directory.display(), "Type #2 UKI directory not found");
+        } else {
+            tracing::warn!(path = %directory.display(), error = ?err, "rejecting unsafe Type #2 UKI directory");
+        }
+        return Vec::new();
+    }
+    let entries = match fs::read_dir(&directory) {
+        Ok(entries) => entries,
+        Err(err) if err.kind() == io::ErrorKind::NotFound => {
+            tracing::debug!(path = %directory.display(), "Type #2 UKI directory not found");
+            return Vec::new();
+        }
+        Err(err) => {
+            tracing::warn!(path = %directory.display(), error = ?err, "cannot scan Type #2 UKI directory");
+            return Vec::new();
+        }
+    };
+
+    let mut boot_entries = Vec::new();
+    for entry in entries {
+        let entry = match entry {
+            Ok(entry) => entry,
+            Err(err) => {
+                tracing::warn!(path = %directory.display(), error = ?err, "cannot read Type #2 UKI directory entry");
+                continue;
+            }
+        };
+        let path = entry.path();
+        let is_regular = entry.file_type().is_ok_and(|file_type| file_type.is_file());
+        let is_efi = path
+            .extension()
+            .and_then(|extension| extension.to_str())
+            .is_some_and(|extension| extension.eq_ignore_ascii_case("efi"));
+        if !is_regular || !is_efi {
+            tracing::debug!(path = %path.display(), is_regular, is_efi, "ignoring non-UKI Type #2 directory entry");
+            continue;
+        }
+
+        match direct_uki_entries_for_file(partition, &mount.root, &path) {
+            Ok(entries) => boot_entries.extend(entries),
+            Err(err) => {
+                tracing::warn!(path = %path.display(), error = ?err, "ignoring malformed Type #2 UKI candidate")
+            }
+        }
+    }
+    boot_entries
