+
+#[derive(Clone, Copy, Debug, Eq, PartialEq)]
+struct ConservativeArm64DtbLayout {
+    staging_address: u64,
+    staging_end: u64,
+    packed_end: u64,
+    relocated_address: u64,
+    relocated_end: u64,
+    headroom: u64,
+}
+
+// This bounds the documented ARM64 Image placement as well as the Android
+// staging span. It is deliberately conservative; it is not a proof of a
+// particular device's proprietary boot-loader decompression policy.
+fn conservative_arm64_dtb_layout(
+    config: &BootImgConfig,
+    packed_size: u64,
+    image_size: u64,
+    text_offset: u64,
+) -> Result<ConservativeArm64DtbLayout> {
+    let staging_address = config
+        .base
+        .checked_add(config.kernel_offset)
+        .ok_or_else(|| "kernel staging address overflows u64".to_string())?;
+    let staging_end = staging_address
+        .checked_add(image_size)
+        .ok_or_else(|| "decompressed kernel staging end overflows u64".to_string())?;
+    let packed_end = staging_address
+        .checked_add(packed_size)
+        .ok_or_else(|| "packed kernel staging end overflows u64".to_string())?;
+    let aligned_base = staging_address & !(ARM64_PLACEMENT_ALIGNMENT - 1);
+    let relocated_address = aligned_base
+        .checked_add(text_offset)
+        .ok_or_else(|| "conservative relocated kernel address overflows u64".to_string())?;
+    let relocated_end = relocated_address
+        .checked_add(image_size)
+        .ok_or_else(|| "conservative relocated kernel end overflows u64".to_string())?;
+    let dtb_addr = config
+        .base
+        .checked_add(config.dtb_offset)
+        .ok_or_else(|| "DTB load address overflows u64".to_string())?;
+
+    let furthest_end = staging_end.max(packed_end).max(relocated_end);
+    if furthest_end > dtb_addr {
+        return Err(format!(
+            "kernel payload may overlap DTB load address: staging=[0x{staging_address:x},0x{staging_end:x}) packed-end=0x{packed_end:x} conservative-relocated=[0x{relocated_address:x},0x{relocated_end:x}) dtb=0x{dtb_addr:x} image={image_size} bytes text-offset=0x{text_offset:x}"
+        ));
+    }
+    Ok(ConservativeArm64DtbLayout {
+        staging_address,
+        staging_end,
+        packed_end,
+        relocated_address,
+        relocated_end,
+        headroom: dtb_addr - furthest_end,
+    })
+}
+
+fn arm64_image_layout(image: &[u8], description: &str) -> Result<Arm64ImageLayout> {
+    if image.len() < ARM64_IMAGE_MIN_SIZE {
+        return Err(format!(
+            "{description} is smaller than an arm64 Image header: {} < {ARM64_IMAGE_MIN_SIZE}",
+            image.len()
+        ));
+    }
+    if &image[ARM64_IMAGE_MAGIC_OFFSET..ARM64_IMAGE_MAGIC_OFFSET + ARM64_IMAGE_MAGIC.len()]
+        != ARM64_IMAGE_MAGIC
+    {
+        return Err(format!("{description} is not a raw arm64 Image"));
+    }
+
+    let declared = u64::from_le_bytes(
+        image[ARM64_IMAGE_SIZE_OFFSET..ARM64_IMAGE_SIZE_OFFSET + 8]
+            .try_into()
+            .unwrap(),
+    );
+    let text_offset = if declared == 0 {
+        ARM64_LEGACY_TEXT_OFFSET
+    } else {
+        u64::from_le_bytes(
+            image[ARM64_IMAGE_TEXT_OFFSET_OFFSET..ARM64_IMAGE_TEXT_OFFSET_OFFSET + 8]
+                .try_into()
+                .unwrap(),
+        )
+    };
+    let file_size = u64::try_from(image.len())
+        .map_err(|_| format!("{description} file size does not fit u64"))?;
+    Ok(Arm64ImageLayout {
+        memory_size: declared.max(file_size),
+        text_offset,
+    })
+}
