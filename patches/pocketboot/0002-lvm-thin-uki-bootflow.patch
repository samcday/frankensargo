+    fn has_arg(invocation: &CommandInvocation, expected: &str) -> bool {
+        invocation.args.iter().any(|arg| arg == expected)
+    }
+
+    fn has_pair(invocation: &CommandInvocation, option: &str, value: &str) -> bool {
+        invocation
+            .args
+            .windows(2)
+            .any(|pair| pair[0] == option && pair[1] == value)
+    }
