+
+pub(super) fn build(target_dir: &Path, target: &str) -> Result<ThinToolsInstall> {
+    if target != TARGET {
+        return Err(format!(
+            "thin_check is not pinned for target {target}; supported target: {TARGET}"
+        ));
+    }
+
+    let paths = ThinToolsPaths::new(target_dir, target);
+    let input = stamp_input(target);
+    if cache_hit(&paths, &input)? {
+        return Ok(paths.install());
+    }
+
+    fs::create_dir_all(&paths.root)
+        .map_err(|err| format!("create {}: {err}", paths.root.display()))?;
+    for package in PACKAGES {
+        let archive = paths.archive(package);
+        ensure_archive(&archive, package)?;
+        extract_payload(&archive, &paths.payload(package), package)?;
+    }
+    verify_closure(&paths)?;
+    let stamp = ThinToolsStamp {
+        input,
+        outputs: output_stamp(&paths)?,
+    };
+    let contents =
+        toml::to_string_pretty(&stamp).map_err(|err| format!("encode thin-tools stamp: {err}"))?;
+    fs::write(&paths.stamp, contents)
+        .map_err(|err| format!("write {}: {err}", paths.stamp.display()))?;
+    Ok(paths.install())
+}
+
+fn stamp_input(target: &str) -> StampInput {
+    StampInput {
+        recipe_version: RECIPE_VERSION,
+        target: target.to_string(),
+        alpine_release: ALPINE_RELEASE.to_string(),
+        alpine_arch: ALPINE_ARCH.to_string(),
+        packages: PACKAGES
+            .iter()
+            .copied()
+            .map(|package| StampPackage {
+                key: package.key.to_string(),
+                package: package.package.to_string(),
+                repository: package.repository.to_string(),
+                url: package.url(),
+                aports_commit: package.aports_commit.to_string(),
+                apk_sha256: package.apk_sha256.to_string(),
+                member: package.member.to_string(),
+                payload_sha256: package.payload_sha256.to_string(),
+            })
+            .collect(),
+    }
+}
+
+fn cache_hit(paths: &ThinToolsPaths, input: &StampInput) -> Result<bool> {
+    let contents = match fs::read_to_string(&paths.stamp) {
+        Ok(contents) => contents,
+        Err(err) if err.kind() == std::io::ErrorKind::NotFound => return Ok(false),
+        Err(err) => return Err(format!("read {}: {err}", paths.stamp.display())),
+    };
+    let Ok(stamp) = toml::from_str::<ThinToolsStamp>(&contents) else {
+        return Ok(false);
+    };
+    if stamp.input != *input || verify_closure(paths).is_err() {
+        return Ok(false);
+    }
+    Ok(stamp.outputs == output_stamp(paths)?)
+}
+
+fn ensure_archive(path: &Path, package: PackagePin) -> Result<()> {
+    if path.is_file() {
+        return verify_hash(path, package.apk_sha256, "Alpine APK");
+    }
+    fs::create_dir_all(
+        path.parent()
+            .ok_or_else(|| format!("APK path has no parent: {}", path.display()))?,
+    )
+    .map_err(|err| format!("create archive directory: {err}"))?;
+    let tmp = path.with_extension("apk.tmp");
+    remove_stale(&tmp)?;
+    let curl = env::var_os("CURL").unwrap_or_else(|| "curl".into());
+    let mut command = Command::new(curl);
+    command
+        .args(["--fail", "--location", "--output"])
+        .arg(&tmp)
+        .arg(package.url());
+    run_command(command, &format!("download {}", package.package))?;
+    verify_hash(&tmp, package.apk_sha256, "Alpine APK")?;
+    fs::rename(&tmp, path)
+        .map_err(|err| format!("rename {} to {}: {err}", tmp.display(), path.display()))
+}
+
+fn extract_payload(archive: &Path, output: &Path, package: PackagePin) -> Result<()> {
+    ensure_file(archive, "Alpine APK")?;
+    let tmp = output.with_extension("tmp");
+    remove_stale(&tmp)?;
+    let file = File::create(&tmp).map_err(|err| format!("create {}: {err}", tmp.display()))?;
+    let bsdtar = env::var_os("BSDTAR").unwrap_or_else(|| "bsdtar".into());
+    let mut command = Command::new(bsdtar);
+    command
+        .arg("-xOf")
+        .arg(archive)
+        .arg(package.member)
+        .stdout(Stdio::from(file));
+    run_command(command, &format!("extract {}", package.member))?;
+    verify_hash(&tmp, package.payload_sha256, package.key)?;
+    fs::set_permissions(&tmp, fs::Permissions::from_mode(0o755))
+        .map_err(|err| format!("chmod {}: {err}", tmp.display()))?;
+    fs::rename(&tmp, output)
+        .map_err(|err| format!("rename {} to {}: {err}", tmp.display(), output.display()))
+}
+
+fn remove_stale(path: &Path) -> Result<()> {
+    match fs::remove_file(path) {
+        Ok(()) => Ok(()),
+        Err(err) if err.kind() == std::io::ErrorKind::NotFound => Ok(()),
+        Err(err) => Err(format!("remove stale {}: {err}", path.display())),
+    }
+}
+
+fn output_stamp(paths: &ThinToolsPaths) -> Result<Vec<StampOutput>> {
+    PACKAGES
+        .iter()
+        .copied()
+        .map(|package| {
+            let path = paths.payload(package);
+            Ok(StampOutput {
+                key: package.key.to_string(),
+                sha256: hash_file(&path)?,
+                bytes: fs::metadata(&path)
+                    .map_err(|err| format!("stat {}: {err}", path.display()))?
+                    .len(),
+            })
+        })
+        .collect()
+}
+
+fn verify_closure(paths: &ThinToolsPaths) -> Result<()> {
+    for package in PACKAGES {
+        verify_hash(&paths.payload(package), package.payload_sha256, package.key)?;
+    }
+    verify_elf_file(
+        &paths.root.join("pdata_tools"),
+        Some(MUSL_INTERPRETER),
+        &["libc.musl-aarch64.so.1", "libgcc_s.so.1", "libudev.so.1"],
+        None,
+    )?;
+    verify_elf_file(
+        &paths.root.join("loader"),
+        None,
+        &[],
+        Some("libc.musl-aarch64.so.1"),
+    )?;
+    verify_elf_file(
+        &paths.root.join("libgcc"),
+        None,
+        &["libc.musl-aarch64.so.1"],
+        Some("libgcc_s.so.1"),
+    )?;
+    verify_elf_file(
+        &paths.root.join("libudev"),
+        None,
+        &["libc.musl-aarch64.so.1"],
+        Some("libudev.so.1"),
+    )
+}
+
+fn verify_hash(path: &Path, expected: &str, description: &str) -> Result<()> {
+    let actual = hash_file(path)?;
+    if actual == expected {
+        Ok(())
+    } else {
+        Err(format!(
+            "{description} checksum mismatch for {}: expected {expected}, got {actual}",
+            path.display()
+        ))
+    }
+}
+
+fn hash_file(path: &Path) -> Result<String> {
+    let mut file = File::open(path).map_err(|err| format!("open {}: {err}", path.display()))?;
+    let mut hasher = Sha256::new();
+    let mut buffer = [0; 64 * 1024];
+    loop {
+        let read = file
+            .read(&mut buffer)
+            .map_err(|err| format!("read {}: {err}", path.display()))?;
+        if read == 0 {
+            break;
+        }
+        hasher.update(&buffer[..read]);
+    }
+    Ok(format!("{:x}", hasher.finalize()))
+}
+
+fn verify_elf_file(
+    path: &Path,
+    interpreter: Option<&str>,
+    needed: &[&str],
+    soname: Option<&str>,
+) -> Result<()> {
+    let bytes = fs::read(path).map_err(|err| format!("read {}: {err}", path.display()))?;
+    let info = inspect_aarch64_elf(&bytes)
+        .map_err(|err| format!("verify ELF {}: {err}", path.display()))?;
+    let expected_needed = needed
+        .iter()
+        .map(|value| (*value).to_string())
+        .collect::<BTreeSet<_>>();
+    if info.interpreter.as_deref() != interpreter {
+        return Err(format!(
+            "unexpected interpreter for {}: expected {interpreter:?}, got {:?}",
+            path.display(),
+            info.interpreter
+        ));
+    }
+    if info.needed != expected_needed {
+        return Err(format!(
+            "unexpected DT_NEEDED closure for {}: expected {expected_needed:?}, got {:?}",
+            path.display(),
+            info.needed
+        ));
+    }
+    if info.soname.as_deref() != soname {
+        return Err(format!(
+            "unexpected SONAME for {}: expected {soname:?}, got {:?}",
+            path.display(),
+            info.soname
+        ));
+    }
+    Ok(())
+}
+
+#[derive(Debug, Eq, PartialEq)]
+struct ElfInfo {
+    interpreter: Option<String>,
+    needed: BTreeSet<String>,
+    soname: Option<String>,
+}
+
+#[derive(Clone, Copy)]
+struct LoadSegment {
+    offset: u64,
+    vaddr: u64,
+    filesz: u64,
+}
+
+fn inspect_aarch64_elf(bytes: &[u8]) -> Result<ElfInfo> {
+    if bytes.len() < ELF64_HEADER_SIZE || bytes.get(..4) != Some(b"\x7fELF") {
+        return Err("not an ELF file".to_string());
+    }
+    if bytes[4] != ELFCLASS64 || bytes[5] != ELFDATA2LSB || bytes[6] != 1 {
+        return Err("expected little-endian ELF64 version 1".to_string());
+    }
+    if !matches!(read_u16(bytes, 16, "ELF type")?, ET_EXEC | ET_DYN) {
+        return Err("unsupported ELF type".to_string());
+    }
+    if read_u16(bytes, 18, "ELF machine")? != EM_AARCH64 {
+        return Err("ELF is not AArch64".to_string());
+    }
+
+    let phoff = to_usize(read_u64(bytes, 32, "program header offset")?)?;
+    let phentsize = usize::from(read_u16(bytes, 54, "program header entry size")?);
+    let phnum = usize::from(read_u16(bytes, 56, "program header count")?);
+    if phentsize < ELF64_PROGRAM_HEADER_SIZE || phnum == 0 {
+        return Err("ELF has no usable program headers".to_string());
+    }
+    let table_end = phoff
+        .checked_add(
+            phentsize
+                .checked_mul(phnum)
+                .ok_or_else(|| "program header table size overflows".to_string())?,
+        )
+        .ok_or_else(|| "program header table end overflows".to_string())?;
+    if table_end > bytes.len() {
+        return Err("program header table exceeds ELF".to_string());
+    }
+
+    let mut loads = Vec::new();
+    let mut dynamic = None;
+    let mut interpreter = None;
+    for index in 0..phnum {
+        let start = phoff + index * phentsize;
+        let header = &bytes[start..start + phentsize];
+        let offset = read_u64(header, 8, "segment offset")?;
+        let filesz = read_u64(header, 32, "segment size")?;
+        match read_u32(header, 0, "segment type")? {
+            PT_LOAD => {
+                checked_file_range(bytes, offset, filesz, "load segment")?;
+                loads.push(LoadSegment {
+                    offset,
+                    vaddr: read_u64(header, 16, "segment virtual address")?,
+                    filesz,
+                });
+            }
+            PT_DYNAMIC => {
+                if dynamic.replace((offset, filesz)).is_some() {
+                    return Err("ELF contains multiple dynamic segments".to_string());
+                }
+            }
+            PT_INTERP => {
+                if interpreter.is_some() {
+                    return Err("ELF contains multiple interpreters".to_string());
+                }
+                let raw = checked_file_range(bytes, offset, filesz, "interpreter")?;
+                interpreter = Some(read_nul_string(raw, 0, "interpreter")?);
+            }
+            _ => {}
+        }
+    }
+    if loads.is_empty() {
+        return Err("ELF contains no load segment".to_string());
+    }
+
+    let mut needed_offsets = Vec::new();
+    let mut soname_offset = None;
+    let mut strtab_vaddr = None;
+    let mut strtab_size = None;
+    if let Some((offset, size)) = dynamic {
+        let raw = checked_file_range(bytes, offset, size, "dynamic segment")?;
+        if raw.is_empty() || raw.len() % ELF64_DYNAMIC_ENTRY_SIZE != 0 {
+            return Err("malformed ELF dynamic segment".to_string());
+        }
+        let mut terminated = false;
+        for entry in raw.chunks_exact(ELF64_DYNAMIC_ENTRY_SIZE) {
+            let tag = read_u64(entry, 0, "dynamic tag")?;
+            let value = read_u64(entry, 8, "dynamic value")?;
+            match tag {
+                DT_NULL => {
+                    terminated = true;
+                    break;
+                }
+                DT_NEEDED => needed_offsets.push(value),
+                DT_STRTAB => strtab_vaddr = Some(value),
+                DT_STRSZ => strtab_size = Some(value),
+                DT_SONAME => soname_offset = Some(value),
+                _ => {}
+            }
+        }
+        if !terminated {
+            return Err("ELF dynamic segment is not terminated".to_string());
+        }
+    }
+
+    let needs_strings = !needed_offsets.is_empty() || soname_offset.is_some();
+    let strtab = if needs_strings {
+        let address = strtab_vaddr.ok_or_else(|| "ELF has no DT_STRTAB".to_string())?;
+        let size = strtab_size.ok_or_else(|| "ELF has no DT_STRSZ".to_string())?;
+        let offset = virtual_to_file_offset(&loads, address)?;
+        checked_file_range(bytes, offset, size, "dynamic string table")?
+    } else {
+        &[]
+    };
+    let mut needed = BTreeSet::new();
+    for offset in needed_offsets {
+        let name = read_nul_string(strtab, to_usize(offset)?, "DT_NEEDED")?;
+        if !needed.insert(name.clone()) {
+            return Err(format!("duplicate DT_NEEDED entry: {name}"));
+        }
+    }
+    let soname = soname_offset
+        .map(|offset| read_nul_string(strtab, to_usize(offset)?, "DT_SONAME"))
+        .transpose()?;
+    Ok(ElfInfo {
+        interpreter,
+        needed,
+        soname,
+    })
+}
+
+fn virtual_to_file_offset(loads: &[LoadSegment], address: u64) -> Result<u64> {
+    for load in loads {
+        let end = load
+            .vaddr
+            .checked_add(load.filesz)
+            .ok_or_else(|| "load segment address overflows".to_string())?;
+        if (load.vaddr..end).contains(&address) {
+            return load
+                .offset
+                .checked_add(address - load.vaddr)
+                .ok_or_else(|| "string table file offset overflows".to_string());
+        }
+    }
+    Err("dynamic string table is outside load segments".to_string())
+}
+
+fn checked_file_range<'a>(
+    bytes: &'a [u8],
+    offset: u64,
+    size: u64,
+    description: &str,
+) -> Result<&'a [u8]> {
+    let start = to_usize(offset)?;
+    let len = to_usize(size)?;
+    let end = start
+        .checked_add(len)
+        .ok_or_else(|| format!("{description} end overflows"))?;
+    bytes
+        .get(start..end)
+        .ok_or_else(|| format!("{description} exceeds ELF file"))
+}
+
+fn read_nul_string(bytes: &[u8], offset: usize, description: &str) -> Result<String> {
+    let tail = bytes
+        .get(offset..)
+        .ok_or_else(|| format!("{description} string offset exceeds table"))?;
+    let end = tail
+        .iter()
+        .position(|byte| *byte == 0)
+        .ok_or_else(|| format!("{description} string is not NUL terminated"))?;
+    if end == 0 {
+        return Err(format!("{description} string is empty"));
+    }
+    std::str::from_utf8(&tail[..end])
+        .map(str::to_string)
+        .map_err(|err| format!("{description} is not UTF-8: {err}"))
+}
+
+fn to_usize(value: u64) -> Result<usize> {
+    usize::try_from(value).map_err(|_| format!("value does not fit usize: {value}"))
+}
+
+fn read_u16(bytes: &[u8], offset: usize, description: &str) -> Result<u16> {
+    let value = bytes
+        .get(offset..offset + 2)
+        .ok_or_else(|| format!("{description} is truncated"))?;
+    Ok(u16::from_le_bytes(value.try_into().unwrap()))
+}
+
+fn read_u32(bytes: &[u8], offset: usize, description: &str) -> Result<u32> {
+    let value = bytes
+        .get(offset..offset + 4)
+        .ok_or_else(|| format!("{description} is truncated"))?;
+    Ok(u32::from_le_bytes(value.try_into().unwrap()))
+}
+
+fn read_u64(bytes: &[u8], offset: usize, description: &str) -> Result<u64> {
+    let value = bytes
+        .get(offset..offset + 8)
+        .ok_or_else(|| format!("{description} is truncated"))?;
+    Ok(u64::from_le_bytes(value.try_into().unwrap()))
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    #[test]
+    fn provenance_pins_the_complete_official_closure() {
+        let input = stamp_input(TARGET);
+        assert_eq!(input.packages.len(), 4);
+        assert_eq!(input.alpine_release, "v3.23");
+        assert!(input.packages.iter().all(|package| {
+            package.apk_sha256.len() == 64
+                && package.payload_sha256.len() == 64
+                && package.aports_commit.len() == 40
+                && package.url.starts_with("https://dl-cdn.alpinelinux.org/")
+        }));
+        assert_eq!(
+            input
+                .packages
+                .iter()
+                .map(|package| package.key.as_str())
+                .collect::<Vec<_>>(),
+            ["pdata_tools", "loader", "libgcc", "libudev"]
+        );
+    }
+
+    #[test]
+    fn rejects_non_elf_and_wrong_architecture() {
+        assert!(
+            inspect_aarch64_elf(b"not ELF")
+                .unwrap_err()
+                .contains("not an ELF")
+        );
+        let mut elf = minimal_elf();
+        elf[18..20].copy_from_slice(&62u16.to_le_bytes());
+        assert!(
+            inspect_aarch64_elf(&elf)
+                .unwrap_err()
+                .contains("not AArch64")
+        );
+    }
+
+    #[test]
+    fn rejects_out_of_bounds_program_headers() {
+        let mut elf = minimal_elf();
+        elf[32..40].copy_from_slice(&u64::MAX.to_le_bytes());
+        assert!(
+            inspect_aarch64_elf(&elf)
+                .unwrap_err()
+                .contains("program header table")
+        );
+    }
+
+    fn minimal_elf() -> Vec<u8> {
+        let mut elf = vec![0; ELF64_HEADER_SIZE + ELF64_PROGRAM_HEADER_SIZE];
+        elf[..4].copy_from_slice(b"\x7fELF");
+        elf[4] = ELFCLASS64;
+        elf[5] = ELFDATA2LSB;
+        elf[6] = 1;
+        elf[16..18].copy_from_slice(&ET_DYN.to_le_bytes());
+        elf[18..20].copy_from_slice(&EM_AARCH64.to_le_bytes());
+        elf[32..40].copy_from_slice(&(ELF64_HEADER_SIZE as u64).to_le_bytes());
+        elf[54..56].copy_from_slice(&(ELF64_PROGRAM_HEADER_SIZE as u16).to_le_bytes());
+        elf[56..58].copy_from_slice(&1u16.to_le_bytes());
+        elf[ELF64_HEADER_SIZE..ELF64_HEADER_SIZE + 4].copy_from_slice(&PT_LOAD.to_le_bytes());
+        elf
+    }
+}
