+    impl TempTree {
+        fn new() -> Self {
+            let mut root = std::env::temp_dir();
+            let nonce = SystemTime::now()
+                .duration_since(UNIX_EPOCH)
+                .unwrap()
+                .as_nanos();
+            root.push(format!(
+                "pocketboot-pbread1-test-{}-{nonce}",
+                std::process::id()
+            ));
+            let paths = SystemPaths {
+                sys_block: root.join("sys-block"),
+                dev_root: root.join("dev"),
+                mountinfo: root.join("proc/mountinfo"),
+                swaps: root.join("proc/swaps"),
+                usb_gadgets: root.join("config/usb_gadget"),
+            };
+            fs::create_dir_all(&paths.sys_block).unwrap();
+            fs::create_dir_all(&paths.dev_root).unwrap();
+            fs::create_dir_all(paths.mountinfo.parent().unwrap()).unwrap();
+            fs::create_dir_all(&paths.usb_gadgets).unwrap();
+            fs::write(&paths.mountinfo, "").unwrap();
+            fs::write(&paths.swaps, "Filename Type Size Used Priority\n").unwrap();
+            Self { root, paths }
+        }
+
+        fn add_partition(
+            &self,
+            disk: &str,
+            kernel_name: &str,
+            partition_number: u32,
+            partuuid32: &str,
+            devnum: &str,
+        ) {
+            let disk_sysfs = self.paths.sys_block.join(disk);
+            fs::create_dir_all(disk_sysfs.join("queue")).unwrap();
+            fs::write(disk_sysfs.join("queue/logical_block_size"), "512\n").unwrap();
+            let partition_sysfs = disk_sysfs.join(kernel_name);
+            fs::create_dir_all(partition_sysfs.join("holders")).unwrap();
+            fs::write(
+                partition_sysfs.join("partition"),
+                partition_number.to_string(),
+            )
+            .unwrap();
+            fs::write(partition_sysfs.join("start"), START_LBA.to_string()).unwrap();
+            fs::write(partition_sysfs.join("size"), SECTORS.to_string()).unwrap();
+            fs::write(partition_sysfs.join("dev"), devnum).unwrap();
+            fs::write(
+                partition_sysfs.join("uevent"),
+                format!("PARTNAME=userdata\nPARTUUID={}\n", hyphenated(partuuid32)),
+            )
+            .unwrap();
+            fs::write(self.paths.dev_root.join(kernel_name), "").unwrap();
+            write_gpt_disk(
+                &self.paths.dev_root.join(disk),
+                partition_number,
+                partuuid32,
+            );
+        }
+    }
+
+    impl Drop for TempTree {
+        fn drop(&mut self) {
+            let _ = fs::remove_dir_all(&self.root);
+        }
+    }
+
+    fn write_gpt_disk(path: &Path, partition_number: u32, partuuid32: &str) {
+        let entry_offset = 2 * 512 + (partition_number as usize - 1) * GPT_ENTRY_MIN_BYTES;
+        let mut disk = vec![0u8; entry_offset + GPT_ENTRY_MIN_BYTES];
+        disk[512..520].copy_from_slice(GPT_SIGNATURE);
+        disk[512 + 12..512 + 16].copy_from_slice(&(GPT_HEADER_MIN_BYTES as u32).to_le_bytes());
+        disk[512 + 72..512 + 80].copy_from_slice(&2u64.to_le_bytes());
+        disk[512 + 80..512 + 84].copy_from_slice(&128u32.to_le_bytes());
+        disk[512 + 84..512 + 88].copy_from_slice(&(GPT_ENTRY_MIN_BYTES as u32).to_le_bytes());
+
+        let entry = &mut disk[entry_offset..entry_offset + GPT_ENTRY_MIN_BYTES];
+        entry[0..16].copy_from_slice(&guid_to_gpt(PARTTYPE));
+        entry[16..32].copy_from_slice(&guid_to_gpt(partuuid32));
+        entry[32..40].copy_from_slice(&START_LBA.to_le_bytes());
+        entry[40..48].copy_from_slice(&(START_LBA + SECTORS - 1).to_le_bytes());
+        for (index, unit) in "userdata".encode_utf16().enumerate() {
+            entry[56 + index * 2..58 + index * 2].copy_from_slice(&unit.to_le_bytes());
+        }
+        fs::write(path, disk).unwrap();
+    }
+
+    fn guid_to_gpt(value: &str) -> [u8; 16] {
+        let canonical = (0..16)
+            .map(|index| u8::from_str_radix(&value[index * 2..index * 2 + 2], 16).unwrap())
+            .collect::<Vec<_>>();
+        [
+            canonical[3],
+            canonical[2],
+            canonical[1],
+            canonical[0],
+            canonical[5],
+            canonical[4],
+            canonical[7],
+            canonical[6],
+            canonical[8],
+            canonical[9],
+            canonical[10],
+            canonical[11],
+            canonical[12],
+            canonical[13],
+            canonical[14],
+            canonical[15],
+        ]
+    }
+
+    fn hyphenated(value: &str) -> String {
+        format!(
+            "{}-{}-{}-{}-{}",
+            &value[0..8],
+            &value[8..12],
+            &value[12..16],
+            &value[16..20],
+            &value[20..32]
+        )
+    }
+}
