+fn open_external_initrd(root: &Path, path: &Path) -> io::Result<(File, u64)> {
+    verify_beneath_without_symlinks(root, path)?;
+    let file = OpenOptions::new()
+        .read(true)
+        .custom_flags(libc::O_NOFOLLOW | libc::O_CLOEXEC)
+        .open(path)
+        .map_err(|err| {
+            io::Error::new(
+                err.kind(),
+                format!("open BLS initrd {}: {err}", path.display()),
+            )
+        })?;
+    let metadata = file.metadata().map_err(|err| {
+        io::Error::new(
+            err.kind(),
+            format!("stat BLS initrd {}: {err}", path.display()),
+        )
+    })?;
+    if !metadata.file_type().is_file() {
+        return Err(invalid_data(format!(
+            "BLS initrd is not a regular file: {}",
+            path.display()
+        )));
+    }
+    let bytes = metadata.len();
+    if bytes == 0 {
+        return Err(invalid_data(format!(
+            "BLS initrd is empty: {}",
+            path.display()
+        )));
+    }
+    if bytes > MAX_INITRD_PAYLOAD_BYTES {
+        return Err(initrd_size_limit_error(path, bytes));
+    }
+    Ok((file, bytes))
+}
+
+fn external_initrd_len(root: &Path, path: &Path) -> io::Result<u64> {
+    open_external_initrd(root, path).map(|(_, bytes)| bytes)
+}
+
+fn read_external_initrd_bounded(root: &Path, path: &Path) -> io::Result<Vec<u8>> {
+    let (file, expected) = open_external_initrd(root, path)?;
+    let initial_capacity = usize::try_from(expected.min(1024 * 1024))
+        .expect("bounded initial initrd capacity fits usize");
+    let mut data = Vec::with_capacity(initial_capacity);
+    file.take(expected + 1)
+        .read_to_end(&mut data)
+        .map_err(|err| {
+            io::Error::new(
+                err.kind(),
+                format!("read BLS initrd {}: {err}", path.display()),
+            )
+        })?;
+    if data.len() as u64 != expected {
+        return Err(invalid_data(format!(
+            "BLS initrd changed while reading: {}",
+            path.display()
+        )));
+    }
+    Ok(data)
+}
+
+fn append_external_initrds(
+    root: &Path,
+    embedded: &mut Option<Vec<u8>>,
+    paths: &[PathBuf],
+) -> io::Result<()> {
+    if paths.is_empty() {
+        return Ok(());
+    }
+
+    let mut combined = embedded.take().unwrap_or_default();
+    for path in paths {
+        let data = read_external_initrd_bounded(root, path)?;
+        append_initrd_component(&mut combined, &data)?;
+    }
+    *embedded = Some(combined);
+    Ok(())
+}
+
+fn append_initrd_component(combined: &mut Vec<u8>, component: &[u8]) -> io::Result<()> {
+    if component.is_empty() {
+        return Err(invalid_data("cannot append an empty initrd component"));
+    }
+    let current = combined.len() as u64;
+    let next = combined_initrd_len(current, component.len() as u64)?;
+    let padding = initrd_padding(current);
+    let next = usize::try_from(next)
+        .map_err(|_| invalid_data("combined initrd size does not fit memory"))?;
+    combined
+        .try_reserve_exact(next - combined.len())
+        .map_err(|err| invalid_data(format!("allocate combined initrd: {err}")))?;
+    // Linux's initramfs buffer grammar permits arbitrary NUL separators. Four
+    // byte alignment also satisfies the newc header/trailer alignment rule.
+    combined.resize(combined.len() + padding as usize, 0);
+    combined.extend_from_slice(component);
+    Ok(())
+}
+
+fn combined_initrd_len(current: u64, component: u64) -> io::Result<u64> {
+    let bytes = current
+        .checked_add(initrd_padding(current))
+        .and_then(|bytes| bytes.checked_add(component))
+        .ok_or_else(|| invalid_data("combined initrd size overflows"))?;
+    if bytes > MAX_INITRD_PAYLOAD_BYTES {
+        return Err(invalid_data(format!(
+            "combined initrd is {bytes} bytes, exceeding the 256 MiB limit"
+        )));
+    }
+    Ok(bytes)
+}
+
+fn initrd_padding(bytes: u64) -> u64 {
+    if bytes == 0 {
+        0
+    } else {
+        (INITRD_ALIGNMENT - bytes % INITRD_ALIGNMENT) % INITRD_ALIGNMENT
+    }
+}
+
+fn initrd_size_limit_error(path: &Path, bytes: u64) -> io::Error {
+    invalid_data(format!(
+        "BLS initrd {} is {bytes} bytes, exceeding the 256 MiB logical file limit",
+        path.display()
+    ))
+}
