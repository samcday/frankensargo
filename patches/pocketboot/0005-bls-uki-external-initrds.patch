+fn bls_uki_initrd_paths(
+    root: &Path,
+    source: &Path,
+    context: &BlsContext,
+    bls: &BlsSnippet,
+    mut combined_bytes: u64,
+) -> io::Result<Option<Vec<PathBuf>>> {
+    let mut paths = Vec::new();
+    for configured in &bls.initrds {
+        let expanded = context.expand(configured);
+        let words = split_bls_words(&expanded);
+        if words.is_empty() {
+            return Err(invalid_data("BLS UKI initrd value is empty"));
+        }
+        for value in words {
+            let path = resolve_boot_path(root, &value)?;
+            let bytes = match external_initrd_len(root, &path) {
+                Ok(bytes) => bytes,
+                Err(err) if err.kind() == io::ErrorKind::NotFound => {
+                    tracing::warn!(source = %source.display(), initrd = %path.display(), "BLS UKI initrd payload is missing");
+                    return Ok(None);
+                }
+                Err(err) => return Err(err),
+            };
+            combined_bytes = combined_initrd_len(combined_bytes, bytes)?;
+            paths.push(path);
+        }
+    }
+    Ok(Some(paths))
+}
