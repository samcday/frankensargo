+fn parse_loader_default(text: &str) -> Option<String> {
+    let mut default = None;
+    for line in text.lines() {
+        let line = line.trim();
+        if line.is_empty() || line.starts_with('#') {
+            continue;
+        }
+        let (key, value) = split_key_value(line);
+        if key == "default" && !value.is_empty() && value.split_ascii_whitespace().count() == 1 {
+            default = Some(value.to_string());
+        }
+    }
+    default
