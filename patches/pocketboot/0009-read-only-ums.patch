+
+#[cfg(test)]
+mod tests {
+    use super::*;
+    use std::time::{SystemTime, UNIX_EPOCH};
+
+    #[test]
+    fn configures_every_mass_storage_lun_read_only() {
+        let temp = TempDir::new();
+
+        configure_mass_storage_lun(&temp.path).unwrap();
+
+        assert_eq!(fs::read_to_string(temp.path.join("ro")).unwrap(), "1");
+        assert_eq!(fs::read_to_string(temp.path.join("cdrom")).unwrap(), "0");
+        assert_eq!(fs::read_to_string(temp.path.join("nofua")).unwrap(), "0");
+        assert_eq!(
+            fs::read_to_string(temp.path.join("removable")).unwrap(),
+            "1"
+        );
+        assert_eq!(
+            fs::read_to_string(temp.path.join("inquiry_string")).unwrap(),
+            MASS_STORAGE_INQUIRY
+        );
+    }
+
+    struct TempDir {
+        path: PathBuf,
+    }
+
+    impl TempDir {
+        fn new() -> Self {
+            let nonce = SystemTime::now()
+                .duration_since(UNIX_EPOCH)
+                .unwrap()
+                .as_nanos();
+            let path = std::env::temp_dir().join(format!(
+                "pocketboot-gadget-test-{}-{nonce}",
+                std::process::id()
+            ));
+            fs::create_dir(&path).unwrap();
+            Self { path }
+        }
+    }
+
+    impl Drop for TempDir {
+        fn drop(&mut self) {
+            let _ = fs::remove_dir_all(&self.path);
+        }
+    }
+}
