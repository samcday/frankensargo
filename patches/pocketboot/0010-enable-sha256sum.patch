+
+#[cfg(test)]
+mod tests {
+    use super::*;
+    use std::time::{SystemTime, UNIX_EPOCH};
+
+    #[test]
+    fn default_recipe_enables_sha256sum_and_invalidates_old_cache() {
+        let temp = TempDir::new();
+        let config = temp.path.join(".config");
+        fs::write(&config, "# CONFIG_SHA256SUM is not set\n").unwrap();
+
+        configure_busybox(&config, &FeatureSet::default()).unwrap();
+
+        let configured = fs::read_to_string(config).unwrap();
+        assert_eq!(BUSYBOX_RECIPE_VERSION, 5);
+        assert_eq!(configured.matches("CONFIG_SHA256SUM=y").count(), 1);
+        assert!(!configured.contains("# CONFIG_SHA256SUM is not set"));
+    }
+
+    struct TempDir {
+        path: PathBuf,
+    }
+
+    impl TempDir {
+        fn new() -> Self {
+            let nonce = SystemTime::now()
+                .duration_since(UNIX_EPOCH)
+                .unwrap()
+                .as_nanos();
+            let path = std::env::temp_dir().join(format!(
+                "pocketboot-busybox-test-{}-{nonce}",
+                std::process::id()
+            ));
+            fs::create_dir(&path).unwrap();
+            Self { path }
+        }
+    }
+
+    impl Drop for TempDir {
+        fn drop(&mut self) {
+            let _ = fs::remove_dir_all(&self.path);
+        }
+    }
+}
