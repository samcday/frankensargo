+
+fn guarded_configfs_teardown(
+    tty_closed: bool,
+    teardown: impl FnOnce() -> io::Result<()>,
+    quarantine: impl FnOnce(),
+) -> io::Result<()> {
+    if !tty_closed {
+        quarantine();
+        return Err(io::Error::new(
+            io::ErrorKind::TimedOut,
+            "refusing configfs teardown while ttyGS0 may still be open",
+        ));
+    }
+    teardown()
+}
+
+fn run_bounded_teardown<T, F>(resource: T, timeout: Duration, teardown: F) -> io::Result<()>
+where
+    T: Send + 'static,
+    F: FnOnce(T) -> io::Result<()> + Send + 'static,
+{
+    // Capacity one keeps handing the resource to the disposable worker
+    // non-blocking even if the scheduler has not run that thread yet.
+    let (work_tx, work_rx) = mpsc::sync_channel(1);
+    let (result_tx, result_rx) = mpsc::sync_channel(1);
+    let thread = match thread::Builder::new()
+        .name("pocketboot-gadget-teardown".to_string())
+        .spawn(move || {
+            let Ok(resource) = work_rx.recv() else {
+                return;
+            };
+            let _ = result_tx.send(teardown(resource));
+        }) {
+        Ok(thread) => thread,
+        Err(err) => {
+            // Do not drop a RegGadget on this thread when a teardown worker
+            // cannot be created: its destructor performs the same configfs
+            // rmdir that this isolation is designed to contain.
+            mem::forget(resource);
+            return Err(io::Error::new(
+                err.kind(),
+                format!("spawn isolated gadget teardown: {err}"),
+            ));
+        }
+    };
+
+    if let Err(mpsc::SendError(resource)) = work_tx.send(resource) {
+        mem::forget(resource);
+        return Err(io::Error::other(
+            "isolated gadget teardown worker exited before accepting work",
+        ));
+    }
+
+    match result_rx.recv_timeout(timeout) {
+        Ok(result) => {
+            if thread.join().is_err() {
+                return Err(io::Error::other("isolated gadget teardown thread panicked"));
+            }
+            result
+        }
+        Err(mpsc::RecvTimeoutError::Timeout) => {
+            // Dropping JoinHandle detaches only the disposable worker. Even if
+            // it is now in uninterruptible configfs sleep, PID 1 and its UART
+            // recovery services remain schedulable.
+            Err(io::Error::new(
+                io::ErrorKind::TimedOut,
+                format!(
+                    "isolated gadget teardown exceeded {} ms",
+                    timeout.as_millis()
+                ),
+            ))
+        }
+        Err(mpsc::RecvTimeoutError::Disconnected) => {
+            let _ = thread.join();
+            Err(io::Error::other(
+                "isolated gadget teardown exited without a result",
+            ))
+        }
     }
 }
 
