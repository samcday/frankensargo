+struct FastbootWorkers {
+    adb_server: Option<adb::ServerHandle>,
+    fastboot_events: Option<fastboot::EventLoop>,
+    adb_events: Option<adb::EventLoop>,
+    kmsg_forwarder: Option<kmsg_forwarder::Handle>,
+}
+
+struct WorkerShutdown {
+    tty_closed: bool,
+    errors: Vec<String>,
+}
+
+impl FastbootWorkers {
+    fn new(acm: bool) -> Self {
+        let kmsg_forwarder = if acm {
+            match kmsg_forwarder::spawn() {
+                Ok(handle) => Some(handle),
+                Err(err) => {
+                    tracing::warn!(error = ?err, "failed to spawn kmsg forwarder");
+                    None
+                }
+            }
+        } else {
+            None
+        };
+        Self {
+            adb_server: None,
+            fastboot_events: None,
+            adb_events: None,
+            kmsg_forwarder,
+        }
+    }
+
+    fn start(
+        &mut self,
+        fastboot_function: fastboot::UsbFunction,
+        adb_function: adb::UsbFunction,
+    ) -> io::Result<fastboot::FastbootServer> {
+        let (server, event_loop) = fastboot_function.start()?;
+        self.fastboot_events = Some(event_loop);
+
+        let (adb_server, event_loop) = adb_function.start()?;
+        self.adb_events = Some(event_loop);
+        self.adb_server = Some(adb_server.spawn()?);
+        Ok(server)
+    }
+
+    fn request_stop(&self) {
+        if let Some(server) = &self.adb_server {
+            server.stop();
+        }
+        if let Some(events) = &self.fastboot_events {
+            events.stop();
+        }
+        if let Some(events) = &self.adb_events {
+            events.stop();
+        }
+        if let Some(forwarder) = &self.kmsg_forwarder {
+            forwarder.request_stop();
+        }
+    }
+
+    fn shutdown(&mut self) -> WorkerShutdown {
+        self.request_stop();
+        let mut errors = Vec::new();
+
+        if let Some(server) = self.adb_server.take()
+            && let Err(err) = server.join()
+        {
+            errors.push(format!("adb server shutdown failed: {err}"));
+        }
+        if let Some(events) = self.fastboot_events.take() {
+            events.join();
+        }
+        if let Some(events) = self.adb_events.take() {
+            events.join();
+        }
+
+        let tty_closed = match self.kmsg_forwarder.take() {
+            None => true,
+            Some(forwarder) => {
+                let shutdown = forwarder.stop_and_join(KMSG_SHUTDOWN_TIMEOUT);
+                let tty_closed = shutdown.tty_closed();
+                match shutdown {
+                    kmsg_forwarder::Shutdown::Joined => {}
+                    kmsg_forwarder::Shutdown::Panicked => {
+                        errors.push("kmsg forwarder panicked during shutdown".to_string());
+                    }
+                    kmsg_forwarder::Shutdown::TimedOut => {
+                        errors.push(format!(
+                            "kmsg forwarder did not close ttyGS0 within {} ms",
+                            KMSG_SHUTDOWN_TIMEOUT.as_millis()
+                        ));
+                    }
+                }
+                tty_closed
+            }
+        };
+
+        WorkerShutdown { tty_closed, errors }
+    }
+}
+
+impl Drop for FastbootWorkers {
+    fn drop(&mut self) {
+        let shutdown = self.shutdown();
+        for error in shutdown.errors {
+            tracing::warn!(error, "USB worker cleanup failed while unwinding");
+        }
+    }
+}
