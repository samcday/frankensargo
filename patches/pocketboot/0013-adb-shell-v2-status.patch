+fn run_shell_v2_reader(mut reader: File, id: u8, output: mpsc::SyncSender<(u8, Vec<u8>)>) {
+    let mut buffer = [0; SHELL_V2_CHUNK];
+    loop {
+        let read = match read_fd(&mut reader, &mut buffer) {
+            Ok(0) => return,
+            Ok(read) => read,
+            Err(err) => {
+                tracing::debug!(id, error = ?err, "adb shell-v2 child output read failed");
+                return;
+            }
+        };
+        if output.send((id, buffer[..read].to_vec())).is_err() {
+            return;
+        }
+    }
+}
+
+#[allow(clippy::too_many_arguments)]
+fn run_shell_v2_output(
+    stdout: File,
+    stderr: File,
+    mut child: Child,
+    writer: PacketWriter,
+    local_id: u32,
+    remote_id: u32,
+    child_running: Arc<AtomicBool>,
+    output: Arc<OutputFlow>,
+) {
+    // Bound queued output so a slow or disconnected USB host cannot turn
+    // unbounded subprocess output into unbounded initramfs memory use.
+    let (sender, receiver) = mpsc::sync_channel(2);
+    let stdout_sender = sender.clone();
+    let stdout_thread =
+        thread::spawn(move || run_shell_v2_reader(stdout, SHELL_V2_STDOUT, stdout_sender));
+    let stderr_thread = thread::spawn(move || run_shell_v2_reader(stderr, SHELL_V2_STDERR, sender));
+
+    let mut stream_open = true;
+    while let Ok((id, data)) = receiver.recv() {
+        let packet = match shell_v2_packet(id, &data) {
+            Ok(packet) => packet,
+            Err(err) => {
+                tracing::debug!(local_id, remote_id, error = ?err, "adb shell-v2 frame failed");
+                stream_open = false;
+                break;
+            }
+        };
+        if !send_stream_payload(&writer, local_id, remote_id, &output, &packet) {
+            stream_open = false;
+            break;
+        }
+    }
+
+    if !stream_open {
+        terminate_process_group(child.id());
+    }
+    drop(receiver);
+    if stdout_thread.join().is_err() {
+        tracing::warn!(local_id, remote_id, "adb shell-v2 stdout thread panicked");
+        stream_open = false;
+    }
+    if stderr_thread.join().is_err() {
+        tracing::warn!(local_id, remote_id, "adb shell-v2 stderr thread panicked");
+        stream_open = false;
+    }
+
+    let status = child.wait();
+    child_running.store(false, Ordering::Release);
+    let exit_code = match status {
+        Ok(status) => shell_v2_exit_code(status),
+        Err(err) => {
+            tracing::debug!(local_id, remote_id, error = ?err, "adb shell-v2 wait failed");
+            1
+        }
+    };
+
+    if stream_open {
+        let exit_packet = shell_v2_packet(SHELL_V2_EXIT, &[exit_code])
+            .expect("one-byte shell-v2 exit packet is always valid");
+        stream_open = send_stream_payload(&writer, local_id, remote_id, &output, &exit_packet);
+    }
+
+    // Do not close the outer ADB stream until the host acknowledges the exit
+    // frame.  A missing acknowledgement instead causes Drop/teardown to wake
+    // this waiter, preserving truncation as a host-side failure.
+    if stream_open
+        && output.wait_for_write_credit()
+        && output.close()
+        && let Err(err) = writer.send(A_CLSE, local_id, remote_id, &[])
+    {
+        tracing::debug!(local_id, remote_id, error = ?err, "adb shell-v2 close send failed");
+    }
+}
