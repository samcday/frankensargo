+struct ShellV2Session {
+    local_id: u32,
+    remote_id: u32,
+    stdin: Option<ChildStdin>,
+    input_buffer: Vec<u8>,
+    child_pid: u32,
+    child_running: Arc<AtomicBool>,
+    output: Arc<OutputFlow>,
+    output_thread: Option<thread::JoinHandle<()>>,
+}
+
+impl ShellV2Session {
+    fn spawn(
+        local_id: u32,
+        remote_id: u32,
+        command: String,
+        writer: PacketWriter,
+    ) -> io::Result<Self> {
+        let (stdin, stdout, stderr, child) = spawn_shell_v2_command(&command)?;
+        let child_pid = child.id();
+        let child_running = Arc::new(AtomicBool::new(true));
+        let output = Arc::new(OutputFlow::new());
+        let thread_child_running = child_running.clone();
+        let thread_output = output.clone();
+        let output_thread = thread::Builder::new()
+            .name(format!("pocketboot-adb-shell-v2-{local_id}"))
+            .spawn(move || {
+                run_shell_v2_output(
+                    stdout,
+                    stderr,
+                    child,
+                    writer,
+                    local_id,
+                    remote_id,
+                    thread_child_running,
+                    thread_output,
+                )
+            })?;
+
+        Ok(Self {
+            local_id,
+            remote_id,
+            stdin: Some(stdin),
+            input_buffer: Vec::new(),
+            child_pid,
+            child_running,
+            output,
+            output_thread: Some(output_thread),
+        })
+    }
+
+    fn allow_output(&self) {
+        self.output.allow_one_write();
+    }
+
+    fn acknowledge_output(&self) {
+        self.output.allow_one_write();
+    }
+
+    fn write_input(&mut self, data: &[u8]) -> io::Result<()> {
+        self.input_buffer.extend_from_slice(data);
+        for packet in parse_shell_v2_input(&mut self.input_buffer)? {
+            match packet {
+                ShellV2Input::Stdin(data) => {
+                    let Some(stdin) = self.stdin.as_mut() else {
+                        return Err(io::Error::new(
+                            io::ErrorKind::BrokenPipe,
+                            "adb shell-v2 stdin is closed",
+                        ));
+                    };
+                    stdin.write_all(&data)?;
+                }
+                ShellV2Input::CloseStdin => {
+                    self.stdin.take();
+                }
+                ShellV2Input::WindowSize(_) => {
+                    // Bootstrap commands explicitly request raw (-T) mode, so
+                    // a window-size update has no process-side effect.
+                }
+            }
+        }
+        Ok(())
+    }
+
+    fn close_from_host(&mut self, writer: &PacketWriter) -> io::Result<()> {
+        let send_close = self.close();
+        if send_close {
+            writer.send(A_CLSE, self.local_id, self.remote_id, &[])?;
+        }
+        Ok(())
+    }
+
+    fn close_from_device(&mut self, writer: &PacketWriter) -> io::Result<()> {
+        let send_close = self.close();
+        if send_close {
+            writer.send(A_CLSE, self.local_id, self.remote_id, &[])?;
+        }
+        Ok(())
+    }
+
+    fn close(&mut self) -> bool {
+        self.stdin.take();
+        if self.child_running.swap(false, Ordering::AcqRel) {
+            terminate_process_group(self.child_pid);
+        }
+        self.output.close()
+    }
+}
+
+impl Drop for ShellV2Session {
+    fn drop(&mut self) {
+        self.close();
+        if let Some(thread) = self.output_thread.take()
+            && thread.join().is_err()
+        {
+            tracing::warn!(pid = self.child_pid, "adb shell-v2 output thread panicked");
+        }
+    }
+}
