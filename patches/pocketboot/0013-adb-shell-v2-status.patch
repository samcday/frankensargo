+#[derive(Debug, Clone, PartialEq, Eq)]
+enum ShellV2Input {
+    Stdin(Vec<u8>),
+    CloseStdin,
+    WindowSize(Vec<u8>),
+}
+
+fn parse_shell_v2_input(buffer: &mut Vec<u8>) -> io::Result<Vec<ShellV2Input>> {
+    let mut packets = Vec::new();
+    loop {
+        if buffer.len() < SHELL_V2_HEADER_LEN {
+            return Ok(packets);
+        }
+        let id = buffer[0];
+        let length = u32::from_le_bytes(buffer[1..5].try_into().unwrap()) as usize;
+        if length > MAX_PAYLOAD as usize {
+            return Err(io::Error::new(
+                io::ErrorKind::InvalidData,
+                "adb shell-v2 inner packet is too large",
+            ));
+        }
+        let total = SHELL_V2_HEADER_LEN.checked_add(length).ok_or_else(|| {
+            io::Error::new(
+                io::ErrorKind::InvalidData,
+                "adb shell-v2 inner packet length overflow",
+            )
+        })?;
+        if buffer.len() < total {
+            return Ok(packets);
+        }
+        let payload = buffer[SHELL_V2_HEADER_LEN..total].to_vec();
+        buffer.drain(..total);
+        let packet = match id {
+            SHELL_V2_STDIN => ShellV2Input::Stdin(payload),
+            SHELL_V2_CLOSE_STDIN if payload.is_empty() => ShellV2Input::CloseStdin,
+            SHELL_V2_WINDOW_SIZE => ShellV2Input::WindowSize(payload),
+            SHELL_V2_CLOSE_STDIN => {
+                return Err(io::Error::new(
+                    io::ErrorKind::InvalidData,
+                    "adb shell-v2 close-stdin packet has a payload",
+                ));
+            }
+            _ => {
+                return Err(io::Error::new(
+                    io::ErrorKind::InvalidData,
+                    format!("unsupported adb shell-v2 input id {id}"),
+                ));
+            }
+        };
+        packets.push(packet);
+    }
+}
+
+fn shell_v2_packet(id: u8, payload: &[u8]) -> io::Result<Vec<u8>> {
+    let length = u32::try_from(payload.len()).map_err(|_| {
+        io::Error::new(
+            io::ErrorKind::InvalidInput,
+            "adb shell-v2 payload length overflows u32",
+        )
+    })?;
+    let mut packet = Vec::with_capacity(SHELL_V2_HEADER_LEN + payload.len());
+    packet.push(id);
+    packet.extend_from_slice(&length.to_le_bytes());
+    packet.extend_from_slice(payload);
+    Ok(packet)
+}
+
+fn shell_v2_exit_code(status: ExitStatus) -> u8 {
+    if let Some(code) = status.code() {
+        return u8::try_from(code).unwrap_or(1);
+    }
+    status
+        .signal()
+        .and_then(|signal| u8::try_from(signal).ok())
+        .map(|signal| 0x80 | signal)
+        .unwrap_or(1)
+}
